  "translations": {
    "en": {
      "description": {
        "text": "Fun climbing, but the routes are short. It may be worth a visit if you live in Gothenburg and have already climbed everything else; otherwise, climb the other stuff first.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:hjallbo"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hjallbo"
            ]
          },
          "body": {
            "text": "Fun climbing, but the routes are short. It may be worth a visit if you live in Gothenburg and have already climbed everything else; otherwise, climb the other crags first.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hjallbo"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hjallbo"
            ]
          },
          "body": {
            "text": "To reach the crag by public transport, take the tram to Hjällbo station. Walk along Gråbovägen towards Gråbo. After passing Hjällbo Lillgata, continue for 100 metres, then turn left onto the cycle path and follow it straight to the crag. The crag is close to the residential area but sufficiently secluded.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hjallbo"
            ]
          }
        },
        "klattring": {
          "title": {
            "text": "Climbing",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hjallbo"
            ]
          },
          "body": {
            "text": "Many short trad routes or mixed routes. The blade bolts found here and there can often be backed up with other protection. There are a few sturdy trees at the top. Most routes are about 8 metres high.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hjallbo"
            ]
          }
        },
        "leder": {
