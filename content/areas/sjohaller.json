      "routes": {
        "sjohaller-led-1": {
          "description": {
            "text": "Cracks and a corner through black rock. One bolt.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjohaller"
            ]
          }
        },
        "sjohaller-led-2": {
          "description": {
            "text": "Starts in the crack left of the large flake. Strenuous crack and corner climbing to a ledge. Traverse 4m right beneath a small roof. Four bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjohaller"
            ]
          }
        },
        "sjohaller-led-3": {
          "description": {
            "text": "Starts by the flake. Thin, strenuous and hard.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjohaller"
            ]
          }
        },
        "sjohaller-led-4": {
          "description": {
            "text": "A long line right of Little Yosemite, starting in an overhang. Five bolts, supplemented by a good selection of nuts and cams. The usual high quality for this crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjohaller"
            ]
          }
        }
      }
