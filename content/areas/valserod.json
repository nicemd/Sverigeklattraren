    {
      "id": "valserod-led-28",
      "kind": "route",
      "number": null,
      "name": "Gör Stor Större",
      "grade": "6+",
      "length": "30",
      "type": "trad",
      "firstAscent": "Niklas Björnerstedt, Lars Svadängs -89",
      "description": "Det jämnare och finare avlutet på Stora väggen. Efter stand på Stora väggen klättra upp lite, traversera höger, och följ den naturliga linjen rakt upp. En bult saknas (sept 2010), något run-out.",
      "sectorId": "stora-vaggen",
      "source": {
