    {
      "id": "valserod-led-21",
      "kind": "route",
      "number": null,
      "name": "Feta Linjen",
      "grade": "8- R",
      "length": "30",
      "type": "trad",
      "firstAscent": "Rein Leidal, Öystein K Johnsen -06",
      "description": "Som Slimline de första 15 m upp till ett horisontellt riss som hanglas till areten till höger. Upp areten ett par meter, så ut på sva till höger. Följ detta till toppen. Leden börjar med ett tak, fortsätter med en fingerspricka, en hangel, en arete och till sist ett psykande sva långt från den sista säkringen. Den här krämleden får med sig det mesta av det bästa på en av Sveriges finaste formationer.",
      "sectorId": "slimlinevaggen",
      "source": {
        "id": "legacy:valserod",
        "path": "mediawiki/Välseröd.txt"
      }
