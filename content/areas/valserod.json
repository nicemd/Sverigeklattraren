    {
      "id": "valserod-led-12",
      "kind": "route",
      "number": null,
      "name": "Villskudd",
      "grade": "6-",
      "length": "40",
      "type": "trad",
      "firstAscent": "Rune Thrap-Meyer, Ulf Geir Hansen, Håkon Staver, Dag Kolsrud, 1980",
      "description": "En av Bohusläns finaste i sin grad. Hangla åt vänster tills du når fingersprickan. Gå rakt upp, fortsätt genom liten diederformation/flak. När sprickan tar slut, kliv ut åt vänster till nästa spricka. Följ denna med dragning åt höger till takets högra sida. Traversera vänster under taket, sedan upp till hyllan. Fortsätt ända till toppen för att få ut max av leden. Några långa slingor hjälper mot repdrag.",
      "sectorId": "villskuddvaggen",
      "source": {
        "id": "legacy:valserod",
        "path": "mediawiki/Välseröd.txt"
      }
    },
