  "translations": {
    "en": {
      "description": {
        "text": "Ramonesklippan, as it is now so aptly named, is in the shade and is ideal for a spot of evening climbing. A couple of the problems are genuinely excellent. Good landings.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:ramonesklippan"
        ]
      },
