      "routes": {
        "gardsas-led-4": {
          "description": {
            "text": "Unusual climbing on crystalline rock.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-6": {
          "description": {
            "text": "At the very back of the corner; has an abseil anchor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-9": {
          "description": {
            "text": "Crack with steep laybacking at the end.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-10": {
          "description": {
            "text": "Project.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-14": {
          "description": {
            "text": "Where Bikupan breaks left after a few metres, continue straight up the corner and through the roof on the left (crux).",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-15": {
          "description": {
            "text": "Airy but well protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-16": {
          "description": {
            "text": "Right of Älgens överaskning. Easy-angled corner climbing to the first roof. Climb through it and up to the next roof, then traverse left. Airy but well protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-17": {
          "description": {
            "text": "Starts as for Luftmadrassen, but traverse right at the first opportunity, then climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-18": {
          "description": {
            "text": "The arete right of Luftmadrassen. Unfortunately, the crux after the initial moves has ground-fall potential: ‘buyer beware’. Otherwise a good route up the left side of the arete. Finishes on a ledge just below the top. Note that Syjuntan never joins Yesterday.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-19": {
          "description": {
            "text": "There is a fixed ‘piece of gear’ in the wide crack at the end.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-21": {
          "description": {
            "text": "Left-leaning crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-22": {
          "description": {
            "text": "Starts at the same place as Set, but after a few metres follows the crack system up right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-26": {
          "description": {
            "text": "Starts as for Dominikas. At the wide, suspect block, climb straight up the wall following vague cracks.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-27": {
          "description": {
            "text": "Crack climbing with the odd awkward section.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-28": {
          "description": {
            "text": "Layback, bridge and pull hard. The jug eventually appears.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-29": {
          "description": {
            "text": "Climb the ramp right of the arete, then move around the arete through a poorly protected crux. Surprisingly well-protected face climbing follows. There is a slightly contrived alternative start (grade 7), beginning left of the arete and protected by one bolt.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-31": {
          "description": {
            "text": "Take one of the cracks right of the ramp to the right-hand edge of the large block. Climb straight up or traverse left beneath the block. Some poorly protected bridging follows above the ledge. The variation starting up the same ramp as Start och Speed is relatively poorly protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-32": {
          "description": {
            "text": "Delicate climbing in a small corner. Make a thin traverse right towards the arete, then follow the left-hand crack towards the top. Probably serious in the first half.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-33": {
          "description": {
            "text": "As for Sträckfisk until after the traverse, then climb the right-hand crack. Strenuous but fine climbing on proper holds.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-34": {
          "description": {
            "text": "Varied climbing up the left of the two large corners. Strenuous hand jams where it steepens.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-35": {
          "description": {
            "text": "Bridging in the large right-hand corner. Relatively well protected; a small Alien can make the crux more comfortable.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-36": {
          "description": {
            "text": "Elegant climbing as you traverse out onto the pillar at the start. A little uneven after that, but good. Well protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-37": {
          "description": {
            "text": "Starts at the very back of the corner, beneath the block that has broken away, and follows the roof. Well protected with large nuts, hexes and tricams; easiest to clean from above. Not for larger climbers.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-38": {
          "description": {
            "text": "Starts as for Travolta. After about 4 m, move left via the crack intersection to the arete. Then climb straight up to the next crack system and the finish. Varied and good.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-39": {
          "description": {
            "text": "Follows the two parallel cracks. A tricky start leads to a considerably easier but less well-protected finish.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-40": {
          "description": {
            "text": "Climbing on fairly positive holds; balancy and acrobatic. Not overly well protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-43": {
          "description": {
            "text": "Juggy catch start in the overhang. An alternative start to the right was added later by Jan P.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
          }
        },
        "gardsas-led-44": {
          "description": {
            "text": "Good practice for aspiring lead climbers. Recommended!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gardsas"
            ]
