        "vagbeskrivning": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:talludden"
            ]
          },
          "body": {
            "text": "Drive on Värmdöleden (222) and turn off at Skuru (just after Skurubron). Turn left and drive under the motorway. Turn right and then left towards Talludden (on Talluddsvägen). Continue straight for a while, then right (Helmdalsvägen), left (Friggvägen), and then right (Emblavägen). Near the end of Emblavägen, there’s a turnaround/parking spot. Park your car there, then follow Mariedalsvägen down. After a few meters, you’ll see a long bouldering wall. Continue down the path towards the water and follow the beach to the right. Musväggen is the wall closest to the beach.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:talludden"
            ]
          }
        },
