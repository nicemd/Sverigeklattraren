  "translations": {
    "en": {
      "description": {
        "text": "A crag right next to the toboggan run in Saltsjöbaden. Small but steep. Predominantly sport climbing. New solo/top-rope routes on the upper wall.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:rodelberget"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rodelberget"
            ]
          },
          "body": {
            "text": "A crag right next to the toboggan run in Saltsjöbaden. Small but steep. Mainly sport climbing. New solo/top-rope routes on the upper wall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rodelberget"
            ]
          }
        },
        "miljo": {
          "title": {
            "text": "Conditions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rodelberget"
            ]
          },
          "body": {
            "text": "West-facing but shady. The upper wall goes into shade at around 3 pm.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rodelberget"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rodelberget"
            ]
          },
          "body": {
            "text": "Head to Solsidans station and turn left just after it. Then immediately turn right onto Slalomvägen and continue for about 200 m before turning right again at the bend where Slalomvägen forks. Follow the road to the end and park considerately. The crag is about a hundred metres to the north. Old coordinates: 10 I NO 752 423",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rodelberget"
            ]
          }
        },
