  "translations": {
    "en": {
      "description": {
        "text": "Slightly overhanging climbing on small holds. The crag is not very high, but has many good routes, particularly in the higher grades. Open setting and close to swimming.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:anneberg"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:anneberg"
            ]
          },
          "body": {
            "text": "Slightly overhanging climbing on small holds. The crag is not very high, but has many fine routes, particularly in the upper grades. Open setting and close to swimming.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:anneberg"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:anneberg"
            ]
          },
          "body": {
            "text": "From Stockholm: take Värmdöleden (road 222), turn off towards \"Skuru/Ektorp/Sjukhus\" (before Skurubron), then turn left and pass under the motorway. Continue straight along Skurusundsvägen; after a while, the crag is on the right, immediately beside the road. Park in the car park next to the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:anneberg"
            ]
          }
        },
        "leder": {
