  "translations": {
    "en": {
      "description": {
        "text": "=General= The area was developed by the SBO crew in 2006 to host Sweden’s largest outdoor bouldering competition. =Directions= From the E4 in Umeå: Turn off the E4 in central Umeå towards road 363, Hissjö/Vindeln. Follow the road for 11 km to the village of Håkmark. Turn right into the village itself. Cross a small bridge and take the first right. Follow the road for a couple of hundred metres to a house with a large sunflower on it, turn left and follow the road into the forest until a green military storehouse appears straight ahead. Turn left onto “Ringvägen” and follow it for about 400 m. Park along the road; the first boulders can be seen at the far edge of the clear-felled area. =Problems=",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:hakmark"
        ]
      },
      "sections": {},
      "routes": {
        "hakmark-problem-1": {
          "description": {
            "text": "Alternative start to no. 30, Geckolina. Start with hands and feet in the crack at the back beneath the roof, then head out towards Geckolina. The rocks supporting the boulder are out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-2": {
          "description": {
            "text": "Sit start (or hanging start if you cannot reach) on the lip at the mine entrance. Traverse left to right, passing The Pledge and ´Til we colapse, and finish via the right arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-3": {
          "description": {
            "text": "The problem goes to the right of problem 19. Follow the crack up; the rock to the left of the crack is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-4": {
          "description": {
            "text": "The problem goes to the right of problem 19. Start on a small low crimp and a sidepull higher up. The rock to the left and the crack are out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-5": {
          "description": {
            "text": "Located 8 m right of no. 3. Low start in the horizontal crack, then straight up via slopers. No exclusions.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-6": {
          "description": {
            "text": "Marked A1. Located 15 m downhill from no. 7, Pushin´, among the introductory boulders towards the road. Sit start on the starting hold; follow the intended line over the small bulge, squeeze, then continue up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-7": {
          "description": {
            "text": "Marked A2. Located 15 m downhill from no. 7, Pushin´, among the introductory boulders towards the road. Sit start on the starting hold and follow the edge of the blunt arete up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-8": {
          "description": {
            "text": "Marked A3. Located 15 m downhill from no. 7, Pushin´, among the introductory boulders towards the road. Start on the starting hold, then follow the line up between the three ‘ears’. The ramp to the left is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-9": {
          "description": {
            "text": "Marked A4. Located 25 m right of no. 7, Pushin´, among the introductory boulders towards the road. Tricky start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hakmark"
            ]
          }
        },
        "hakmark-problem-10": {
          "description": {
            "text": "Marked A5. Located 15 m downhill from no. 7, Pushin´, among the introductory boulders towards the road. Climb the wall to a good finishing hold.",
