      "routes": {
        "spikarna-problem-1": {
          "description": {
            "text": "Start on the large jug/crack and finish with jugs straight up. A few small stones may come loose on the way up ;)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-2": {
          "description": {
            "text": "Starts in the middle of one side of the boulder and finishes straight up, trending slightly right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-3": {
          "description": {
            "text": "Starts on the corner of the boulder and climbs diagonally up right. A little moss on the top-out, but it’s manageable ;)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-4": {
          "description": {
            "text": "Climbs straight up between the two narrow vertical cracks, which form natural boundaries.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-5": {
          "description": {
            "text": "Climbs straight up between the two narrow vertical cracks, which form natural boundaries.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-6": {
          "description": {
            "text": "Climbs straight up between the two narrow vertical cracks, which form natural boundaries.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-7": {
          "description": {
            "text": "Climbs straight up to the right of the narrow vertical crack, which forms a natural boundary on the left. There are many variants to this problem depending on where the right-hand boundary is set. Named by Tony Berglund 2005-09-06.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-8": {
          "description": {
            "text": "Climbs straight up to the right of Svart kaffe & mörk choklad. Arbitrary boundaries...",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-9": {
          "description": {
            "text": "It is unclear whether there are any boundaries; climbs somewhere on the right-hand face, a little way right of Fotöljen.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-10": {
          "description": {
            "text": "Perhaps the finest problem at Spikarna. Climbs diagonally up right from the sloping ledge at the boulder’s left-hand corner. Named by Olle Morén 2005-08-19.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-11": {
          "description": {
            "text": "Climbs straight up from, among other holds, a crimpy and slightly sharp crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-12": {
          "description": {
            "text": "Climbs straight up from the large ledge on the boulder to the right of the boulder with Tony hade slitna skor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-13": {
          "description": {
            "text": "Climbs straight up, slightly right of the centre of the boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-14": {
          "description": {
            "text": "The sit start to Varm vind.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-15": {
          "description": {
            "text": "Climbs straight up inside the cleft. Take care not to fall into the sea!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-16": {
          "description": {
            "text": "Starts out on the corner of the slab and climbs straight up. A technical and fine top-out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-17": {
          "description": {
            "text": "Sit start, climbing straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-18": {
          "description": {
            "text": "Sit start from the right-hand arete, climb three moves up and traverse left. From the small crack, climb onto the slab and traverse across to the rose bush to top out. The rock by the bush is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:spikarna"
            ]
          }
        },
        "spikarna-problem-19": {
          "description": {
            "text": "Straight up, roughly in the middle of the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
