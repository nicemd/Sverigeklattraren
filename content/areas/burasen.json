      "routes": {
        "burasen-led-1": {
          "description": {
            "text": "Obvious left-leaning corner starting with a prominent roof. The roof is passed using an old piton with a sling. The slippery corner is protected with somewhat hard-to-find but good nuts and cams. An old/rotten bolt on the headwall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
          }
        },
        "burasen-led-2": {
          "description": {
            "text": "The free version of Farenheit 450. Pass the roof on the left with a few well-directed pulls, then make a short traverse into the corner. Finish via an obvious finger crack about 1.5 metres right of the bolt. Well protected, with lots of small cams.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
          }
        },
        "burasen-led-6": {
          "description": {
            "text": "The parallel line to the next route. Lower-off anchor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
          }
        },
        "burasen-led-7": {
          "description": {
            "text": "The most obvious left-leaning crack in the middle of the wall. Lower-off anchor slightly to the left at the top. A variation climbs half of Grymt Slut before continuing into Dagstur. This is called Snällt slut and is graded 7.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
          }
        },
        "burasen-led-9": {
          "description": {
            "text": "Lower-off anchor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
          }
        },
        "burasen-led-14": {
          "description": {
            "text": "The bolt at the start looks rusty and is unnecessary. Instead, traverse in from the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
          }
        },
        "burasen-led-17": {
          "description": {
            "text": "Fine crack climbing, but often wet.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:burasen"
            ]
