      "routes": {
        "korpberget-rimforsa-led-7": {
          "description": {
            "text": "Follow the crack that clearly gave the route its name, then an arete to the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "korpberget-rimforsa-led-8": {
          "description": {
            "text": "Big steps just to the right, followed by a finger crack to the top. Both routes can easily be top-roped from a tree.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "korpberget-rimforsa-led-9": {
          "description": {
            "text": "Big steps up to a pine tree.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "korpberget-rimforsa-led-10": {
          "description": {
            "text": "Significantly trickier for taller climbers, who find it a bit cramped in the corner.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "korpberget-rimforsa-led-37": {
          "description": {
            "text": "Long thought to be unrepeated, but a few climbers besides the first ascensionist have wriggled their way into the chimney. Requires specialist protection, such as gigantic gear.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        }
      }
