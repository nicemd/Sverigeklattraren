  "translations": {
    "en": {
      "description": {
        "text": "Take road 34 from Linköping towards Kisa. At the roundabout outside Rimforsa, turn left towards the village. Cross the railway and turn right towards Slätmon. Follow the road for about 6 km until you see the crag on the right. Park a short way along the gravel road after the red cottage, or continue a little further and turn onto a bumpy forest track, then park in the clearing.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:korpberget-rimforsa"
        ]
      },
      "sections": {
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          },
          "body": {
            "text": "Take Route 34 from Linköping towards Kisa. At the roundabout outside Rimforsa, turn left towards the town centre. Cross the railway and turn right towards Slätmon. Follow the road for about 6 km until you see the crag on the right. Park a short way along the gravel road after the red cottage, or continue a little further, turn onto a bumpy forest track and park in the clearing.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          },
          "body": {
            "text": "Korpberget offers mainly trad routes on coarse-grained granite. Many are crack routes, several of them high quality. The friction is very good, but the rock is hard on the fingers.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "vastra-flanken": {
          "title": {
            "text": "West Flank",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "fikavaggen": {
          "title": {
            "text": "Fika Wall",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
