            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
        "amfivaggen": {
          "title": {
            "text": "Amphitheatre Wall",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          },
          "body": {
            "text": "The approach to the starts of the routes on Amphitheatre Wall is an interesting maze of boulders. At the left-hand edge, some kind soul has left a fixed rope.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-rimforsa"
            ]
          }
        },
