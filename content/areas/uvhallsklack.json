        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:uvhallsklack"
            ]
          },
          "body": {
            "text": "From Uppsala, take road 72 to Vittinge and turn left at the sign for Hårsbäck, which takes you over the railway. After 100m, turn left onto Lillbovägen. Drive 400m and then turn right at the T-junction. This road continues east for about 1km before being blocked by a barrier. 100m before the barrier, there is a small parking area on the right. Walk to the barrier. The cliffs are approximately 30m to the left.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:uvhallsklack"
            ]
          }
        },
