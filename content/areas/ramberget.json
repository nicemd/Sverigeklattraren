  "translations": {
    "en": {
      "description": {
        "text": "Ramberget is fairly close to the city centre, but has a poor reputation among local climbers. It offers trad climbing, new-route potential and bouldering.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:ramberget"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "Ramberget is fairly close to the city centre, but has a poor reputation among local climbers. It offers trad, new routing and bouldering.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
        "mer": {
          "title": {
            "text": "More",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "Ramberget has a short approach from the car. However, the crag is extensive, and getting between the different sections may require moving the car.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "The directions in the first edition of the Gothenburg guidebook are incorrect. The crag is further west than indicated. It lies directly below the car park.\n\nThe car park is the one at the top of Ramberget. The roads furthest south are the end of Herkulesgatan and Gamla Rambergsvägen. The mosque is further east along Herkulesgatan.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
        "kollektivtrafik": {
          "title": {
            "text": "Public transport",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "The nearest stop is Ramberget, served by bus 31 from Wieselgrensplatsen.\n\nRamberget, in the middle of Hisingen, offers urban climbing. Quite fun.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
        "stora-plattan": {
          "title": {
            "text": "Stora Plattan",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "The routes lie directly below the car park.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
        "svarta-vaggen": {
          "title": {
            "text": "Svarta väggen",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
        "lavasten": {
          "title": {
            "text": "Lavasten",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          },
          "body": {
            "text": "Because of Lundbyleden, which runs below the crag, it is impossible to hear what your climbing partner is saying at this section. There are more potential lines here for anyone interested in new routing.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ramberget"
            ]
          }
        },
