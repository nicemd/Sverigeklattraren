  "translations": {
    "en": {
      "description": {
        "text": "The crag is on southern Farstalandet, immediately west of Beatelunds gård. It is a fairly large crag with several different sections, some of which drop straight into Kolström, the very narrow strait between Farstalandet and Ingarö. The crag has been fairly thoroughly explored, though there is still potential for more routes.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:beatelund"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:beatelund"
            ]
          },
          "body": {
            "text": "The crag lies on southern Farstalandet, just west of Beatelund farm. It is a fairly large crag with several different sections, some dropping straight into Kolström, the very narrow strait between Farstalandet and Ingarö. The crag has been fairly thoroughly explored, though there is still potential for more routes.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:beatelund"
            ]
          }
        },
        "extern-forare": {
          "title": {
            "text": "External guide",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:beatelund"
            ]
          },
          "body": {
            "text": "A guide with a topo is available on Stockholms Nätförare (http://www.plonk.se/oldsite/beatelund.html)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:beatelund"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:beatelund"
            ]
          },
          "body": {
            "text": "Drive towards Ingarö and turn towards Beatelund before the bridge. After 1.4 km, pass an impressive gate on the left. After another 400 m, the road bends sharply right. Park here. Walk into the woods and head towards the highest point. The red wall lies directly below, with Cabragg on the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:beatelund"
            ]
          }
        },
