            "sourceIds": [
              "legacy:rasklippan"
            ]
          },
          "body": {
            "text": "A newly opened wall with pleasant, easier slab routes in a fine setting. The routes will be bolted.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rasklippan"
            ]
          }
        },
        "ingmars-vagg": {
          "title": {
            "text": "Ingmars vägg",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rasklippan"
            ]
          },
          "body": {
            "text": "An overhanging wall with several fine routes. There is potential for new routes. The crag is almost always dry, even after rain. There are several boulder problems on the right-hand side.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rasklippan"
            ]
          }
        },
