          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rosas"
            ]
          },
          "body": {
            "text": "From Örnsköldsvik, head south along the E4 for about 3 km. Turn right off the E4, signposted Route 348 towards Åsele. After 14 km, turn right onto Molidenvägen. On entering the village, follow the signs for Rösåsberget. Pass a football pitch and an old railway station. Park at the turning area below the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rosas"
            ]
          }
        },
