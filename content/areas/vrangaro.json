      "routes": {
        "vrangaro-led-1": {
          "description": {
            "text": "Cracks and dihedrals through black rock. One bolt.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:vrangaro"
            ]
          }
        },
        "vrangaro-led-2": {
          "description": {
            "text": "Starts in the crack west of the large slab. Heavy crack and dihedral climbing up to a ledge. Traverse right 4m beneath a small roof. Four bolted anchors.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:vrangaro"
            ]
          }
        },
        "vrangaro-led-3": {
          "description": {
            "text": "Starts at the slab. Thin, hard and strenuous.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:vrangaro"
            ]
          }
        },
        "vrangaro-led-4": {
          "description": {
            "text": "Long line to the right of Little Yosemite, starting in a roof. Five bolts complemented by a good selection of nuts and friends. The rock quality is typically high for the area.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:vrangaro"
            ]
          }
        }
      }
