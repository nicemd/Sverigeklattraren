  "translations": {
    "en": {
      "description": {
        "text": "A large crag about 40 metres high and around 500 metres long. Some early ascents were made in the 80s and 90s, while development began in 2011 by Simon Talltorp, and currently, there are around ten routes in the 5/6 grade range. There are great opportunities for first ascents for those looking to clean up!",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:ovrakulla"
        ]
      },
