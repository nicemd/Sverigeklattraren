      "routes": {
        "ovrakulla-led-1": {
          "description": {
            "text": "The route is a bit off, far south on the southern massif. A very fine route with plenty of hand jams. Traverse right under the first roof and then go straight up. The route is divided by two ledges and the exit is the mountain's finest viewpoint.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-2": {
          "description": {
            "text": "Clear dihedral. The upper part requires some larger gear for comfort.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-3": {
          "description": {
            "text": "Starts at the exit of Trainspotting. A short ascent route to the top for those who prefer going up rather than down.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-4": {
          "description": {
            "text": "Starts to the right of the large spruce tree. Goes straight up to a small ledge and then continues through a roof. Follows two distinct cracks up to the large ledge.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-5": {
          "description": {
            "text": "Climb straight up to where the dihedral ends, step slightly right and go straight up a short distance to connect with the cracks just to your left. Follow the crack to the ledge.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-6": {
          "description": {
            "text": "Go up to the left under the roof and establish yourself in the crack. Then follow the wide crack up to the top. Some Camalots #3 and #4 needed for the upper crack, quite a high first gear placement.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-7": {
          "description": {
            "text": "The mighty dihedral becomes steeper and steeper, concluding in vertical climbing. Some larger cams are required for comfortable protection.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-8": {
          "description": {
            "text": "A powerful fridge climbed on the face after stepping up to the right of it. Well-protected and not particularly onsight-friendly.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-9": {
          "description": {
            "text": "An unusual climb following a system of flared cracks. Some sections are runout and not entirely well protected.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-10": {
          "description": {
            "text": "The clear crack in the middle of the wall. Follow the line to the top.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-11": {
          "description": {
            "text": "Goes about 1.5 meters to the right of EN NORSK. Avoid using EN NORSK's crack as they are two independent lines.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        },
        "ovrakulla-led-12": {
          "description": {
            "text": "Aid climb. Likely starts from the left side of the wall, at a left-behind copperhead.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ovrakulla"
            ]
          }
        }
      }
    }
