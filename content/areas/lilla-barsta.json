  "translations": {
    "en": {
      "description": {
        "text": "=General= A pleasant little area close to town. 10–15 boulders of a good height and with good rock quality. The boulders lie in open, airy spruce woodland. Generally very good mossy landings. =Directions= Park at the old bus stop by the turn-off towards Hammarskog. Do NOT drive up the private gravel road. Walk up a small gravel road, passing a slightly too-low boulder in the field. The first boulder is on the left shortly after the edge of the woods.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:lilla-barsta"
        ]
      },
      "sections": {
        "access": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          },
          "body": {
            "text": "=Photo=\n\n=Guide=\n\nThe guide is available here: Media:Lilla_Bärsta.pdf\n\n=Children= Good opportunities for play. A few mosquitoes. Shady. Accessible with an all-terrain pushchair such as a Chariot or similar.\n\n=Problems=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        }
      },
      "routes": {
        "lilla-barsta-problem-1": {
          "description": {
            "text": "Magnificent line on a split boulder: a three-metre hand-jam roof. Sit start as far in as possible, then climb out, over the lip and up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-2": {
          "description": {
            "text": "Standing start to Klassklyftan, taking the vertical section of the crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-3": {
          "description": {
            "text": "On the first boulder, on the left of the track just beyond the edge of the forest. The right-hand variant of the arete-like feature on the back.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-4": {
          "description": {
            "text": "Large, fine boulder directly west of the barrier boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-5": {
          "description": {
            "text": "Keep left of the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-6": {
          "description": {
            "text": "Start in the crack at the far right of the barrier boulder, hand-traverse left and finish up Bominsteget.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-7": {
          "description": {
            "text": "The crack left of S-leden, without using the large ramp on the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-8": {
          "description": {
            "text": "Traverse all the way around the obelisk (‘beneath’ the tree). Start, for example, from the large ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-9": {
          "description": {
            "text": "The arete nearest the rowan on the field boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-10": {
          "description": {
            "text": "Sit start by the arete between Snabbis and Stånk och stön, with the pine directly behind you. LH on the large sidepull/jug and RH on the sloper. Mantel straight up onto the slab.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-11": {
          "description": {
            "text": "On the field boulder, the high arete facing the field, climbed with the body on the right-hand side.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-12": {
          "description": {
            "text": "On the field boulder, right of Cigaretten.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-13": {
          "description": {
            "text": "Right of Klassklyftan.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-15": {
          "description": {
            "text": "A fine boulder about a kilometre north of Bärsta, beyond the clearings visible from Klassklyftan. Steeper and longer than Long John...",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-16": {
          "description": {
            "text": "North of Bärsta, by Ekensberg. A fine line on the arete. 4–5 metres, friction holds. A couple of other interesting lines on the boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-17": {
          "description": {
            "text": "On the barrier boulder. Start just left of Bominsteget and climb straight up. One of Uppsala’s finest at any grade.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-18": {
          "description": {
            "text": "On the barrier boulder. The left-hand arete on the side facing the forest.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-19": {
          "description": {
            "text": "As for I-leden, but starting on the ramp.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-20": {
          "description": {
            "text": "Right of Stenkrossen (which is right of Mandeln, which is right of Storpotäten). Start on a sidepull, then get your foot up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-21": {
          "description": {
            "text": "Follow the track past the barrier boulder. Look right just inside the edge of the forest. An interesting feature!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-22": {
          "description": {
            "text": "On a high boulder about 200 m east of Obelisken. Bear slightly left from the edge of the field and head into the forest. An arete feature beside a large spruce with many sawn-off branches.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-23": {
          "description": {
            "text": "On the same boulder as Först!, around the corner to its right. It only gets three stars if you start below the edge for the left hand, with your left hand on the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-24": {
          "description": {
            "text": "...suddenly, after giving up following two hours of searching for boulders, I find myself standing right in front of a bloody Grandma Peabody. A very impressive boulder about 700 metres west of Klassklyftan.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-25": {
          "description": {
            "text": "Start on the large left-hand jug, then climb straight up to good holds on the slab.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-26": {
          "description": {
            "text": "Same start as Stånk och stön, then hand-traverse right and up to the top. The jugs on the slab used for Stånk och stön are out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-27": {
          "description": {
            "text": "Sit start at the far end by the arete and traverse into Up and Go.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-28": {
          "description": {
            "text": "Sit start, then hand-traverse left and up to the top. Several starts are possible; climbers of average height can reach the starting holds without stacking pads or similar.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-29": {
          "description": {
            "text": "The wall immediately left of the arete problem Cigaretten on the field boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-30": {
          "description": {
            "text": "The slab on the left of the Storpotäten boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-31": {
          "description": {
            "text": "New boulder about 400 m west of Gäddhänget; the left-hand crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-32": {
          "description": {
            "text": "The right-hand crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-33": {
          "description": {
            "text": "The slab on the eastern side.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-34": {
          "description": {
            "text": "Right of Lågspänning.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        },
        "lilla-barsta-problem-35": {
          "description": {
            "text": "The highest arete left of Högspänning.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lilla-barsta"
            ]
          }
        }
      }
    }
  }
}
