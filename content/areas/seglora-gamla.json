  "access": {
    "legacyText": "Markägaren har iordningställt en parkeringsplats och tar ut en klätteravgift på 20 kr per person och dygn. Våren 1996 uppstod konflikt mellan markägare och klättrare, pga allt rännande på hans mark. Detta löstes i och med parkeringsavgiften.",
    "federationSlug": "seglora"
  },
  "qualityIssues": [],
  "provenance": {
    "primarySourceId": "legacy:seglora-gamla",
    "sources": [
