  "sections": [
    {
      "id": "plan-1",
      "title": "plan 1",
      "body": "Stanna vid skylten mot Myggstenen. Ett par block ligger intill vägen om du går tillbaka ett hundratal meter. För att komma till den enorma myggstenen, följ skylten och stigen."
    },
    {
      "id": "plan-2",
      "title": "plan 2",
      "body": "Kör förbi skylten mot Myggsten och parkera istället vid vändplanen. Blocken ligger spridda på hygget söder om vändplanen."
    }
  ],
