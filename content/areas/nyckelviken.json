  "translations": {
    "en": {
      "description": {
        "text": "The area is close to the city, in Nyckelviken Nature Reserve in Nacka, and has around 40 problems.\n\nSee also Kulberget for roped climbing.\n\n2008 guide (the numbering and number of problems do not match this more recent online guide): Media:nyckelviken.pdf",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:nyckelviken"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          },
          "body": {
            "text": "This urban crag lies in Nyckelviken Nature Reserve in Nacka and has around 40 problems.\n\nSee also Kulberget for roped climbing.\n\n2008 guide (The numbering and number of problems do not match this ‘newer’ online guide): Media:nyckelviken.pdf",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "karta-vagbeskrivning": {
          "title": {
            "text": "Map & Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "bil": {
          "title": {
            "text": "By Car",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          },
          "body": {
            "text": "Take road 222 towards Nacka/Värmdö. Take the exit towards Nacka Strand, then turn left at the roundabout and cross the motorway. Turn right at the next roundabout, then follow signs for Nyckelviken.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "buss": {
          "title": {
            "text": "By Bus",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          },
          "body": {
            "text": "Take a bus from Slussen to Forum Nacka or Ektorp Centrum, then walk for about 20 minutes. If you travel to Ektorp Centrum, you will pass the wall at Nacka Sjukhus.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "hitta-fran-parkeringen": {
          "title": {
            "text": "Approach from the Car Park",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          },
          "body": {
            "text": "The boulders are on the right, shortly after the right-angle bend in the gravel road towards Nyckelviken. Just after the bend there is a parking area on the left; park there. Cross the road and follow the left-hand edge of the meadow, past a bench, towards the edge of the woods. Follow a narrow path for about 100 m into the woods.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "oversiktsbild": {
