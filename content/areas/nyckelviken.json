      "routes": {
        "nyckelviken-problem-1": {
          "description": {
            "text": "Straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-2": {
          "description": {
            "text": "Climb the arete only.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-3": {
          "description": {
            "text": "Start as for \"Kantattack\", then climb the face using the edges. The arete and lower ramp are out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-4": {
          "description": {
            "text": "Start as for \"Kantattack\", then traverse left below the edges.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-5": {
          "description": {
            "text": "The only problem that goes right after the start. Finish up the right-hand side.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-6": {
          "description": {
            "text": "Climb straight up the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-7": {
          "description": {
            "text": "Same start as \"Pusher\", moving right via the sloping shelf.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-8": {
          "description": {
            "text": "Climb from the crimps to the sloping edge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-9": {
          "description": {
            "text": "Follow the sloping shelf to the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-10": {
          "description": {
            "text": "Climb to the start of \"Skämt å Sido\", then follow the sloping shelf to the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-11": {
          "description": {
            "text": "Climb to the start of \"Skämt å Sido\", then top out directly above.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-12": {
          "description": {
            "text": "Start at the far right of the cracked block and climb low, finishing at the start of \"Skämt å Sido\". The large crack leading to the top of the boulder is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-13": {
          "description": {
            "text": "Same start as above, but follow the crack up to the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-14": {
          "description": {
            "text": "Hand-traverse from left to right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-15": {
          "description": {
            "text": "Top out directly above.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-16": {
          "description": {
            "text": "Start with both hands on the small block and mantle using the foothold on the left. Do not stand on the small block!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-17": {
          "description": {
            "text": "As above, but move right over the edge instead.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-18": {
          "description": {
            "text": "Start in the starting crack, follow it using small holds, then climb over the edge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-19": {
          "description": {
            "text": "Start in the starting crack and climb via a sloper and a protruding hold to the edge, then climb up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-20": {
          "description": {
            "text": "Start in the starting crack, climb via a sloper, then make a delicate move right using more slopers.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-21": {
          "description": {
            "text": "The problem to the right of \"Herr Martin\", trending diagonally left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-22": {
          "description": {
            "text": "Start as for \"The Cambist\", but climb further right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-23": {
          "description": {
            "text": "As for \"Super Camakazi\", but instead of finishing beneath and around the boulder, climb over the edge when you reach its end.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-24": {
          "description": {
            "text": "Start at the far left and traverse right, finishing beneath the edge and then climbing up. Harder than it looks.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-25": {
          "description": {
            "text": "Start on the edge of the boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-26": {
          "description": {
            "text": "Start on the edges beneath the boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-27": {
          "description": {
            "text": "Sit start, then climb into \"Camakazi\" and finish up it.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-28": {
          "description": {
            "text": "Climb up and left. The ramp is out for feet at the start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-29": {
          "description": {
            "text": "Start as for \"Martins håla\", but move to the right-hand edge. Weird as hell!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-30": {
          "description": {
            "text": "For the small: if possible, start down in the cave...",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-31": {
          "description": {
            "text": "Climb up along the right-hand edge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-32": {
          "description": {
            "text": "?",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-33": {
          "description": {
            "text": "?",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-34": {
          "description": {
            "text": "Climb onto the boulder with the sharp right-hand edge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-35": {
          "description": {
            "text": "Technical and crimpy.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-36": {
          "description": {
            "text": "Established start with the left finger in the hole, right hand on the ledge. Fire right hand to the gaston ledge, left hand to the crimp...",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-37": {
          "description": {
            "text": "Climb up the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
            ]
          }
        },
        "nyckelviken-problem-38": {
          "description": {
            "text": "Dyno to a slightly sharp, crescent-shaped edge a little to the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nyckelviken"
