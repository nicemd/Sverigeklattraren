  "translations": {
    "en": {
      "description": {
        "text": "A high, extensive ‘sea cliff’ fairly close to the city, offering both trad and sport climbing across a wide range of grades.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:ekoberget"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ekoberget"
            ]
          },
          "body": {
            "text": "A large, high waterside crag fairly close to the city, offering both trad and sport climbing across a wide range of grades.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ekoberget"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ekoberget"
            ]
          },
          "body": {
            "text": "Take Värmdöleden (road 222) towards Gustavsberg. Exit at Orminge/Lännersta. Cross the motorway towards Orminge, then follow signs for Gustavsberg (Gamla Värmdövägen). Follow signs for Graninge and park at Graninge Stiftgård. Continue down to the water in the same direction as the road, then turn right and follow the shore. The crag is about 200 metres away.\n\nThe road is currently being dug up. Follow the orange diversion signs.\n\nSee also hitta.se (http://www.hitta.se/ViewDetailsPlace.aspx?PlaceId=2456943&SearchType=4&UCSB%3aWflWhite=1a1b&UCSB%3aWflPink=4a&UCSB%3aTextBoxWho=&UCSB%3aTextBoxWhere=ekoberget)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ekoberget"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ekoberget"
            ]
