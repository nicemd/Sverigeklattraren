            ]
          },
          "body": {
            "text": "The crag is described in the Gothenburg guide under \"other crags\". Local climbers occasionally climb here when there are no access issues.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tumlehed"
            ]
          }
        },
