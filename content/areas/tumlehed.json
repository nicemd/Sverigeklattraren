  "translations": {
    "en": {
      "description": {
        "text": "The crag is described in the Gothenburg guide under \"other crags\". Local climbers sometimes climb here, provided there are no access issues.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:tumlehed"
        ]
      },
