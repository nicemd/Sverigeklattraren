      "routes": {
        "turbo-problem-1": {
          "description": {
            "text": "Green line, sit start, short cruxy route on the arête to the left of the wall/block.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-2": {
          "description": {
            "text": "Red line, sit start, short slightly reachy route mid-wall. Starts low right on double edges and then pulls up left via a side edge. The arêtes are eliminated for hands.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-3": {
          "description": {
            "text": "Blue line, sit start, simply the right arête.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-4": {
          "description": {
            "text": "Blue line, starts easiest on two crimps either side of the arête, then moves right after a catch.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-5": {
          "description": {
            "text": "Red line, starts easiest on two crimps either side of the arête, follows the arête left on slopers and tops out via nice 'homesafe' crystal holds.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-6": {
          "description": {
            "text": "Yellow line, move from high pinch and low crimp and then chill on the arête before continuing up into Mr Hyde for suggestion.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-7": {
          "description": {
            "text": "Red line, starts wide and slopes up the arête with a crack for support, sparse footholds for the right side.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-8": {
          "description": {
            "text": "Yellow line, sit start with crimps, up via a knob and straight up for a slabby top out.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-9": {
          "description": {
            "text": "Green line, sit start with crimps, up via a knob and continue the ramp to the top.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-10": {
          "description": {
            "text": "Purple line, sit start with an arête and crimper, the crux is the start, significantly easier afterwards.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-11": {
          "description": {
            "text": "Yellow line, start with double sidepull/undercling. Nice overhang, up via the left edge.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:turbo"
            ]
          }
        },
        "turbo-problem-12": {
          "description": {
            "text": "Green line, start with double sidepull/undercling. Nice overhang, up via the right edge.",
            "method": "llm",
