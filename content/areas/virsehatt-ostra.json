  "translations": {
    "en": {
      "description": {
        "text": "Description: The crag is 6-8 m high and features both overhanging and steep climbing. All routes are protected with gear, and the opportunity for setting top ropes is good.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:virsehatt-ostra"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:virsehatt-ostra"
            ]
          },
          "body": {
            "text": "Description: The crag is 6-8 m high and features both overhanging and slab climbing. All routes are protected with gear, and the possibility to set up a top rope is good.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:virsehatt-ostra"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:virsehatt-ostra"
            ]
          },
          "body": {
            "text": "Map here. Click the map button above.\n\nThe easiest way to find it is from Oskarström. Drive from Oskarström towards Simlångsdalen and the Virsehatt nature reserve. Upon arriving at the reserve, pass an older building with a sharp roof, Virsestuga. Head straight up the scree slope behind the small house to the left of the cottage for about 50 m; you will then be underneath the crag.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:virsehatt-ostra"
            ]
          }
        },
        "leder": {
