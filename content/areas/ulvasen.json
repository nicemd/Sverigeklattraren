  "translations": {
    "en": {
      "description": {
        "text": "A very nice, but somewhat hidden area that unfortunately seems to be visited less frequently than the more renowned crags closer to the centre. There is no development in sight, and no noise from the E20.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:ulvasen"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          },
          "body": {
            "text": "A very nice, but somewhat hidden area that sadly seems to be visited less often than more well-known crags closer to the city centre. No buildings in sight, no noise from the E20.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "access": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "karaktar": {
          "title": {
            "text": "Character",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          },
          "body": {
            "text": "Distinctive jamming character with a focus around grade 6. Routes are 10-20 meters long. High quality!",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          },
          "body": {
            "text": "To reach here by bike from central Gothenburg, take Utbyvägen from Gamlestan, continue past Utby, and turn left a kilometre later onto Paradisvägen. Where Paradisvägen then takes a right turn, you continue instead up the steep hill on Gavelåsvägen. Where the road ends (after another tough uphill), a well-prepared path begins. Follow the path upwards, that is to the left. Turn off the path to the right after 5-10 minutes, where a sign with a skier is nailed up. Cross the swamp on rotten planks. The crags will be on your right.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
