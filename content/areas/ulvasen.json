      "routes": {
        "ulvasen-led-1": {
          "description": {
            "text": "The crack furthest left. Well protected if you have some extra Camalot 2-3 or similar. Easy for its grade",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-2": {
          "description": {
            "text": "The crack next door. Goes past a tree.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-3": {
          "description": {
            "text": "Starts under the roof.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-4": {
          "description": {
            "text": "Arete left of First Aid.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-5": {
          "description": {
            "text": "The very thin crack right of Adduktur and left of Neverest.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-6": {
          "description": {
            "text": "Steep dihedral with nice hand jams. Well protected, ideally with 2-3 Camalot #2.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-14": {
          "description": {
            "text": "Right-leaning \"staircase\".",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-17": {
          "description": {
            "text": "Crack left of Medusa.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-18": {
          "description": {
            "text": "Crack number 2.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-19": {
          "description": {
            "text": "A really nice finger crack. Consistent and well protected.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-25": {
          "description": {
            "text": "Starts in the niche but transitions into the crack on the left side of the beautiful slab, aim for a block that looks like a fang, about 1½ meters big. Varied and surprisingly consistent climbing.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-29": {
          "description": {
            "text": "Striking line along the arete. Very strenuous.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-30": {
          "description": {
            "text": "Offwidth.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-32": {
          "description": {
            "text": "Varied and exciting line on the left edge of the crag.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-36": {
          "description": {
            "text": "Starts a bit tricky and broken, then excellent hand jams.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        },
        "ulvasen-led-37": {
          "description": {
            "text": "Starts in an overhang, traverse out right, follow the loose flake up, traverse left in the horizontal crack, and then up towards the tree. Probably easy free grade.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:ulvasen"
            ]
          }
        }
      }
    }
