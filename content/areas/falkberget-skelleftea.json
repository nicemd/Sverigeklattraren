  "translations": {
    "en": {
      "description": {
        "text": "Skellefteå’s most popular crag. Routes in all grades, though unfortunately they are becoming overgrown with moss. The routes are spread across four smaller walls.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:falkberget-skelleftea"
        ]
      },
      "sections": {
