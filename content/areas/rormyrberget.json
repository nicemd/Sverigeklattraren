      "routes": {
        "rormyrberget-problem-1": {
          "description": {
            "text": "Sit start to the left of/behind the overhang.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-2": {
          "description": {
            "text": "Climbs the left side of the overhang.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-3": {
          "description": {
            "text": "Start on two good underclings and climb diagonally left towards the arete (not using the hold to the right of the spruce). Exposed.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-4": {
          "description": {
            "text": "To the right of Vittergrottan. Starts left of the pine and climbs straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-5": {
          "description": {
            "text": "On the boulder beside Vittergrottan. Start on the obvious large starting hold and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-6": {
          "description": {
            "text": "On the boulder beside Vittergrottan. Sit start three metres left of Yes, Sir Captain! Follow the arete up and right. Eliminate: keep your feet on the face; stepping onto the arete is not allowed.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-7": {
          "description": {
            "text": "On the isolated face/boulder between Vittergrottan and Tjockisväggarna. The right-hand arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-8": {
          "description": {
            "text": "On the isolated face/boulder between Vittergrottan and Tjockisväggarna. Straight up the middle. A little high.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-9": {
          "description": {
            "text": "On the isolated face/boulder between Vittergrottan and Tjockisväggarna. The left-hand arete. A rather unsuccessful problem; we will have to work out how it should be climbed later.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-10": {
          "description": {
            "text": "Sit start by the arete, then climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-11": {
          "description": {
            "text": "Start matched and follow the small holds upwards.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-13": {
