            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-14": {
          "description": {
            "text": "On the left of the large face. A reasonable height.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:rormyrberget"
            ]
          }
        },
        "rormyrberget-problem-15": {
          "description": {
            "text": "Small face to the right of the large face. A short, sandy problem.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
