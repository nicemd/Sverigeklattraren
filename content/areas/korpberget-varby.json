      "routes": {
        "korpberget-varby-led-1": {
          "description": {
            "text": "Broken climbing past a pine tree towards the roof, which is bypassed on the left. According to the old Stockholm guidebook, parts of the start had collapsed, but this is an exaggeration. Although it is a little blocky near the ground, the climbing itself is intact and good. However, avoid climbing on this edge of the crag during the raven nesting season!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-varby"
            ]
          }
        },
        "korpberget-varby-led-2": {
          "description": {
            "text": "According to the old Stockholm guidebook, this entire route may have collapsed, which is incorrect. The lower section is unpleasantly loose, but the upper half is unchanged, though heavily overgrown.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:korpberget-varby"
            ]
          }
        },
        "korpberget-varby-led-8": {
          "description": {
            "text": "Several variations are possible in the lower section. Higher up, there is laybacking on finger holds.",
