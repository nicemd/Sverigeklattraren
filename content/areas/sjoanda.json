          }
        },
        "description": {
          "title": {
            "text": "Description",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          },
          "body": {
            "text": "One of Sweden’s better sport crags, offering slabby to slightly overhanging routes on solid, red-tinged granite.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          }
        },
        "directions": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          },
          "body": {
            "text": "See the map above. Turn right at the farm and park in the marked parking area. The waymarked path to the crag starts by the barn. Please do not cross farmland or the meadows.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          }
        },
        "season": {
          "title": {
            "text": "Season",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          },
          "body": {
            "text": "The wall faces east and receives sun until 14:00. The best season is June–October.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          }
        },
        "staying-there": {
          "title": {
            "text": "Accommodation",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          },
          "body": {
            "text": "Risebo fritid (http://www.risebofritid.se) has cabins for rent. Överums vandrarhem (hostel) (http://www.overum.nu) is 10 km from the crag. The nearest supermarket is in Överum, 13 km from the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjoanda"
            ]
          }
        }
