  "translations": {
    "en": {
      "description": {
        "text": "A small sport crag by Nolbybacken. The routes here are fairly short but still of a high standard.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:nolby"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "A small sport crag by Nolbybacken. The routes here are fairly short but still of a high standard.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "From Sundsvall: Follow the E4 south to Kvissleby. Turn right, signposted Nolbykullen. Then turn immediately left, i.e. not towards Nolbybacken. Turn right onto Nyavägen, then right again onto Trastvägen. Park on the gravel road 50 m before the barrier.\n\nContinue on foot along the road. Twenty metres after a blue container, a path leads uphill to the right. Follow it for 50 m to reach the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "miljo": {
          "title": {
            "text": "Aspect and surroundings",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "Predominantly north-facing compact rock. The woodland around the crag is fairly sparse, so it dries quite quickly.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "projekt-a-vaggen": {
          "title": {
            "text": "Projekt A Wall",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "The first wall you reach from the path.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "hardrocksvaggen": {
          "title": {
            "text": "Heavy Metal Wall",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "The next wall to the right of Projekt A Wall.",
