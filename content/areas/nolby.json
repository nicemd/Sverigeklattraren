  "sections": [
    {
      "id": "allmant",
      "title": "Allmänt",
      "body": "Liten sportklippa vid Nolbybacken. Lederna här är ganska korta men håller ändå ganska hög klass."
    },
    {
      "id": "vagbeskrivning",
      "title": "Vägbeskrivning",
      "body": "Från Sundsvall: Följ E4:an söderut till Kvissleby. Sväng av åt höger, skyltat Nolbykullen. Ta sedan direkt vänster, dvs ej mot Nolbybacken. Ta sedan höger på Nyavägen. Sväng sedan höger igen på Trastvägen. Parkera på grusvägen 50m innan bommen.\n\nPromenera vidare längs vägen. 20 meter efter en blå container så finns en stig som går upp åt höger. Följ den 50m så är ni vid klippan."
    },
    {
      "id": "miljo",
      "title": "Miljö",
      "body": "Huvudsaklingen nordvänd kompakt klippa. Skogen är ganska gles vid klippan, så den torkar ganska snabbt."
    },
    {
      "id": "leder",
      "title": "Leder",
      "body": ""
    },
    {
      "id": "projekt-a-vaggen",
      "title": "Projekt A-väggen",
      "body": "Den första väggen som man kommer upp till från stigen."
    },
    {
      "id": "hardrocksvaggen",
      "title": "Hårdrocksväggen",
      "body": "Nästa vägg till höger om Projekt A-väggen."
    },
    {
      "id": "ovrevaggen-hogra",
      "title": "Övreväggen, högra",
      "body": "Ligger ovanför Projekt A-väggen. Senslessness kommer upp i klippans vänsterkant."
    },
    {
      "id": "ovrevaggen-vanstra",
      "title": "Övreväggen, vänstra",
      "body": "Ligger övanför Projekt A-väggen. Lättaste sättet att ta sig upp hit är med ett fast rep till vänster om Projekt A-väggen."
    },
    {
      "id": "baksidan",
      "title": "Baksidan",
      "body": "Ligger till vänster om Övreväggen, vänstra."
    }
  ],
