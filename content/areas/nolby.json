              "legacy:nolby"
            ]
          }
        },
        "ovrevaggen-hogra": {
          "title": {
            "text": "Upper Wall, right",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "Located above Projekt A Wall. Senslessness finishes at the left edge of the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "ovrevaggen-vanstra": {
          "title": {
            "text": "Upper Wall, left",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          },
          "body": {
            "text": "Located above Projekt A Wall. The easiest way to get up here is via a fixed rope to the left of Projekt A Wall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby"
            ]
          }
        },
        "baksidan": {
