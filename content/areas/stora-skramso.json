  "translations": {
    "en": {
      "description": {
        "text": "A large but unfortunately hard-to-reach crag in the Stockholm archipelago.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:stora-skramso"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
