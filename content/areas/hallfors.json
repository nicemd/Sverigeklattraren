            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallfors"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallfors"
            ]
          },
          "body": {
            "text": "From the E4: Leave the E4 at the northern entrance to Byske. Take the road towards Fällfors. Just after passing the small village of Hällfors, turn right onto a gravel road. You will now see the crag. Keep right and park directly below the crag. A short, easy walk leads up to the wall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallfors"
            ]
          }
        },
        "leder": {
