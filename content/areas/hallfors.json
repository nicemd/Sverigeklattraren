  "sections": [
    {
      "id": "allmant",
      "title": "Allmänt",
      "body": "Huvudsakligen vertikal, med ett par överhäng. Klippan är ganska lös och grepprik."
    },
    {
      "id": "miljo",
      "title": "Miljö",
      "body": "Sydvänd. Torkar väldigt snabbt."
    },
    {
      "id": "vagbeskrivning",
      "title": "Vägbeskrivning",
      "body": "Från väg E4: Sväng av E4an vid norra infarten till Byske. Ta vägen mot Fällfors. Just som du passerat den lilla byn Hällfors tar du höger in på en grusväg. Nu ser du klippan. Håll höger och parkera rakt nedanför klippan. En lätt promenad leder dig upp till väggen."
    },
    {
      "id": "leder",
      "title": "Leder",
      "body": ""
    },
    {
      "id": "huvudvaggen",
      "title": "Huvudväggen",
      "body": "(från vänster till höger)"
    },
    {
      "id": "hogra-vaggen",
      "title": "Högra väggen",
      "body": "Det som är mest utmärkande med detta väggparti är taket som sträcker sig halva väggens längd. (Leder från vänster till höger)"
    },
    {
      "id": "forare",
      "title": "Förare",
      "body": "Finns med i nätföraren över skellefteå: http://www.skelleftea.org/forening/kfumskelleftea/Webforare/www-filer/start.html"
    }
  ],
