  "translations": {
    "en": {
      "description": {
        "text": "Mainly vertical, with a couple of overhangs. The rock is quite loose and has plenty of holds.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:hallfors"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallfors"
            ]
          },
          "body": {
            "text": "Mainly vertical, with a couple of overhangs. The rock is quite loose and has plenty of holds.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallfors"
            ]
          }
        },
        "miljo": {
