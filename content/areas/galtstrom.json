            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-6": {
          "description": {
            "text": "Sit start with both hands in the large pocket, then follow the arete up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-7": {
          "description": {
            "text": "Start with both hands on the sloping edge to the right of the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-8": {
          "description": {
            "text": "Running or jump start to two gastons on the slab, then straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-9": {
          "description": {
            "text": "Start with both hands on the ramp and climb straight up.",
