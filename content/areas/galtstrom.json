      "routes": {
        "galtstrom-problem-1": {
          "description": {
            "text": "Sit start beneath the overhanging arete. Climb straight up, finishing when you are standing above the overhang.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-2": {
          "description": {
            "text": "Sit start with both hands on the sloping ledge. Traverse right to the arete and climb up there.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-3": {
          "description": {
            "text": "Start on the undercling, then climb up trending left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-4": {
          "description": {
            "text": "A static variant of \"Hole in one\", climbing via the undercling.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:galtstrom"
            ]
          }
        },
        "galtstrom-problem-5": {
          "description": {
            "text": "Dyno from the obvious edge to the hole.",
