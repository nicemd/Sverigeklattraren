      "routes": {
        "junibosand-problem-1": {
          "description": {
            "text": "Sit start with the left hand on the undercling and the right hand on a crimp. Climb straight out through the roof. (Vindkraftverksstenen)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-2": {
          "description": {
            "text": "Sit start at the bottom of the right-hand edge of the overhang. Follow it all the way out, then top out on the short side. (Vindkraftverksstenen)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-3": {
          "description": {
            "text": "Start with both hands on the jug in the overhang, then dyno right to the edge on the side of the boulder. Continue straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-4": {
          "description": {
            "text": "Standing start just right of the 6B traverse. The block on the ramp to the right is out. Follow the slab to the top. (Vindkraftverksstenen)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-5": {
          "description": {
            "text": "Sit start with both hands on the large edge, then follow the arete up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-6": {
          "description": {
            "text": "Sit start at the arete and follow it up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-7": {
          "description": {
            "text": "Start at the small pocket and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-8": {
          "description": {
            "text": "Start at the large pocket and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-9": {
          "description": {
            "text": "Start with the left hand on the good hold and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-10": {
          "description": {
            "text": "Start on the two pockets, then climb straight up via the undercling.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-11": {
          "description": {
            "text": "Start slightly left of \"Stairmaster\" on the same ledge and climb straight up via a series of edges.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-12": {
          "description": {
            "text": "Start with both hands on the lowest ledge and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-13": {
          "description": {
            "text": "Start in the small corner, with the left hand on the arete and the right hand low in the crack. Climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-14": {
          "description": {
            "text": "Start on the obvious sidepull, then climb straight up via the large pocket.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-15": {
          "description": {
            "text": "Start with both hands in the pocket, establish yourself, then climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        },
        "junibosand-problem-16": {
          "description": {
            "text": "Sit start to \"Mutanto\". Start low and to the right, outside the cave/hole.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:junibosand"
            ]
          }
        }
      }
