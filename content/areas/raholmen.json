      "routes": {
        "raholmen-problem-1": {
          "description": {
            "text": "Sit start at the bottom left of the edge and follow it up right. On the boulder by the water below Saga.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-2": {
          "description": {
            "text": "Straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-3": {
          "description": {
            "text": "Sit start at the arete, follow it up, then continue straight up over the large ramp.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-4": {
          "description": {
            "text": "Starts directly in front of the pine tree and goes straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-5": {
          "description": {
            "text": "Starts beyond the roof on the obvious edge 2 metres left of Saga and goes straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-6": {
          "description": {
            "text": "Starts on the two obvious holds in the middle of the roof and goes straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-7": {
          "description": {
            "text": "Starts standing on the rock below and goes straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-8": {
          "description": {
            "text": "Sit-start variant of Stepper.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-9": {
          "description": {
            "text": "Starts with both hands on the good ledge and goes straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-10": {
          "description": {
            "text": "Sit start with both hands on the good hold on the arete, then follow the arete up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-11": {
          "description": {
            "text": "Traverse/link-up starting with Hälsporre, traversing across to Hot Stepper and finishing up it.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-12": {
          "description": {
            "text": "Straight up to the right of Hälsporre. The arete to the right and the starting hold of Hälsporre are out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-13": {
          "description": {
            "text": "Sit start where the ramp meets the ground and go straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-14": {
          "description": {
            "text": "Starts immediately right of Alternativ Uppgång, then trends diagonally up right. The crack on Alternativ Uppgång is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-15": {
          "description": {
            "text": "Follow the crack up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-16": {
          "description": {
            "text": "Straight up the crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-17": {
          "description": {
            "text": "Straight up without moving either right or left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-18": {
          "description": {
            "text": "Follow the arete up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-19": {
          "description": {
            "text": "Straight up left of Bollsinne.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        },
        "raholmen-problem-20": {
          "description": {
            "text": "Starts with the left hand around the edge and goes straight up. Do not move out left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:raholmen"
            ]
          }
        }
      }
