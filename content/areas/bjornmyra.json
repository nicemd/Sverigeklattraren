  "translations": {
    "en": {
      "description": {
        "text": "A low, broad crag with a couple of fun routes and plenty of bouldering potential. Solid, compact rock with a fresh, fairly rough, slightly fiery character and a hint of harshness.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:bjornmyra"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:bjornmyra"
            ]
          },
          "body": {
            "text": "A low, broad crag with a couple of enjoyable routes and plenty of bouldering potential. Solid, compact rock with a fresh, fairly rough, slightly fierce character and a somewhat harsh edge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:bjornmyra"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:bjornmyra"
            ]
          },
          "body": {
            "text": "From Arvika, take road 175 towards Klässbol/Säffle. At the southern Ingestrand turn-off, head up towards Björnmyra. Signposted from the road? The crag is on the far side of the clear-cut area you pass on your left before crossing the stream. However, this crag has seen very little traffic in recent years, so it is in great need of clearing, both at the base (very overgrown) and on the routes!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:bjornmyra"
            ]
          }
        },
        "leder": {
