  "translations": {
    "en": {
      "description": {
        "text": "Very steep crag featuring some of Stockholm's hardest routes, including 8c/8c+.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:svarttjarn"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:svarttjarn"
            ]
          },
          "body": {
            "text": "Very overhanging crag with some of Stockholm's hardest routes, including 8c/8c+.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:svarttjarn"
            ]
          }
        },
        "extern-forare": {
          "title": {
            "text": "External Guide",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:svarttjarn"
            ]
          },
          "body": {
            "text": "A guide with a sketch is available on Stockholm's Network Guide (http://www.plonk.se/snf/svarttjarn.html)\\n\\n(excerpt from Plonk)\\n\\nWarning! The large block to the left of the overhanging wall, out at Svarttjärn, has moved approximately 1 - 1.5 meters down towards the forest. A smaller block (about 1 ton) that was previously wedged between the block and the wall behind has fallen onto the ledge to the left of Corn Flakes, and more are on the way down. It is not advisable to climb on the three to four routes that go on the block. When the block, which is estimated to weigh 150 - 200 tons, decides to slide the last bit before it rolls down into the forest in front of the crag, you do not want to be clipped into one or more of the bolts!",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:svarttjarn"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Access Directions",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:svarttjarn"
            ]
          },
          "body": {
            "text": "Värmdöleden 222. Exit at Ingarö/Gustavsberg towards Ingarö. Right after Brunn, left onto Enkärrsvägen, right onto Svarttjärnsvägen.\\n\\nPark and head into the forest. (Difficult to find, use GPS or the map on SNF (http://plonk.se/oldsite/svarttjarn.html))",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:svarttjarn"
            ]
          }
        },
