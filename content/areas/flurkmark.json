  "translations": {
    "en": {
      "description": {
        "text": "=General=\nThe legendary Flurkmark. , , and with its variants are probably the finest problems here.\n\n=Directions=\nDrive to Flurkmark, then head north towards Tavelsjö. After a few kilometres, there is a sign for the caves on the left. Follow the signs to a large lay-by on the left-hand side of the gravel road. Park and follow the path up towards the caves.\n\n=Problems=\n----\nThe first boulder you come to from the parking area has an overhanging face with a few okay problems.\n----\nThe problems below are on a face 40 metres beyond Bermudataket. Superaretet is superb.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:flurkmark"
        ]
      },
      "sections": {},
      "routes": {
        "flurkmark-problem-1": {
          "description": {
            "text": "The first tall wall on the final approach to the boulder. The obvious wall problem left of the offwidth. Perhaps a little harder if you are short.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-2": {
          "description": {
            "text": "A low problem on the first wall, just before reaching the other walls. The excellent arete on the left. Low.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-3": {
          "description": {
            "text": "Left of Svågerkärlek. A little rubbish problem, if I remember correctly.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-4": {
          "description": {
            "text": "Sit start to the right of the arete on the boulder. A little unsure about the number.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-5": {
          "description": {
            "text": "Short and good.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-6": {
          "description": {
            "text": "Start on the obvious hold beneath the massive undercling. Graded using a kneebar.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-7": {
          "description": {
            "text": "Grade uncertain.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-8": {
          "description": {
            "text": "A little unsure about the number; I think it goes just left of no. 6. Standing start with some good sloper moves.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-9": {
          "description": {
            "text": "High and good.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-10": {
          "description": {
            "text": "Brilliant roof problem. Starts on the marked dots.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-11": {
          "description": {
            "text": "Sit start to Bermudatriangeln. Starts on an undercling and heads out right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-12": {
          "description": {
            "text": "Start as for Breaking Surface, but head straight out through the roof without using the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-14": {
          "description": {
            "text": "Good wall climbing, almost too high.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-15": {
          "description": {
            "text": "Right of Tunn luft. Umeå’s finest 5!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-16": {
          "description": {
            "text": "Right of Superaréten. Low sit start, followed by some really good moves!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flurkmark"
            ]
          }
        },
        "flurkmark-problem-17": {
