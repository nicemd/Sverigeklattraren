  },
  "translations": {
    "en": {
      "description": {
        "text": "=Problem=",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:nolby-bimbo"
        ]
      },
      "sections": {},
      "routes": {
        "nolby-bimbo-problem-1": {
          "description": {
            "text": "Sit-start low on the left, trend diagonally right to the point, then straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-2": {
          "description": {
            "text": "Start laybacking the large vertical crack low on the left, traverse right on edges, then climb straight up over both blocks without using either arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-3": {
          "description": {
            "text": "Start beneath a small overhang on an undercling and a crimp edge. Climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-4": {
          "description": {
            "text": "Sit-start beneath the overhang, climb straight out and up over the bulge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-5": {
          "description": {
            "text": "Start by the crack and climb straight up. On the overhanging wall above the ski jump.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-6": {
          "description": {
            "text": "Follow the arete straight up; reach-dependent. On the overhanging wall above the ski jump.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-7": {
          "description": {
            "text": "Sit-start variation to Lille-Skutt.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-8": {
          "description": {
            "text": "Sit-start with both hands on the sidepull rail, then climb straight out and up over the bulge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-9": {
          "description": {
            "text": "Sit-start with both hands on the jug furthest out beneath the roof, then climb straight out right and up (there is an arrow on the roof). The edge on the left above the roof is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-10": {
          "description": {
            "text": "Sit-start with both hands on the edge. Follow the lip/ridge diagonally up left. The grade partly reflects the height and landing.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-11": {
          "description": {
            "text": "Start hanging from the lip. Rock over the lip and continue up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-12": {
          "description": {
            "text": "Sit-start with both hands on the crimps. Make a semi-dynamic move to the lip.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-13": {
          "description": {
            "text": "Sit-start with both hands on the sidepull edge. Climb straight up via an edge to the lip.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-14": {
          "description": {
            "text": "Sit-start with your left hand on the sloper around the arete and your right hand on a crimp in the overhang. Climb straight up, keeping right. Exposed top-out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-15": {
          "description": {
            "text": "Start beneath the protruding point with your back against the rock. Hoist yourself up until you are sitting on the point. Mongoloid problem.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-16": {
          "description": {
            "text": "Start on the lip at the bottom left of the wall. Dyno diagonally up right to the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-17": {
          "description": {
            "text": "Start on the two edges beneath the small roof. Dyno to the lip of the ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-18": {
          "description": {
            "text": "A traverse starting on the large hold low on the left. Traverse about 10 metres right and finish with both hands on the obvious ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-19": {
          "description": {
            "text": "Follow the obvious arete up onto the ledge. The easiest way down is to abseil from the ledge. The problem is unbrushed, hence the name.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-20": {
          "description": {
            "text": "Sit-start at the back beneath the roof, climb out through it, then up via the crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-21": {
          "description": {
            "text": "Begin with a spectacular jump start to the sloper. Trend slightly left, then climb straight up via the obvious crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-22": {
          "description": {
            "text": "Start to the right of the “bulge”, traverse left across it, then climb up the crack. The problem finishes when you are standing on the “bulge”. See photo!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-23": {
          "description": {
            "text": "Start in the crack without standing on the slope or rock slab. Follow the lip out to the arete, then climb up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-24": {
          "description": {
            "text": "Start as for Big pinch, continue to the ledge, then climb up. See photo!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-25": {
          "description": {
            "text": "Start as for Big pinch, then climb left to Lille skutt and mantle.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-26": {
          "description": {
            "text": "Start low on the edges, then climb to the lip and top out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-27": {
          "description": {
            "text": "Climb straight up the crack without standing on the rock slab at the start. The problem finishes when you are standing on the “bulge”.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-28": {
          "description": {
            "text": "Start inside the “cave”, climb out, then straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-29": {
          "description": {
            "text": "Start as for Bloodgod, climb out to the large edge, then up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-30": {
          "description": {
            "text": "Follow La Magra out to the large edge, then climb up via the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-31": {
          "description": {
            "text": "Begin with a jump start to the lip, then mantle. Easier if you are tall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-32": {
          "description": {
            "text": "Start in the crack inside the cave, then climb straight out and up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-33": {
          "description": {
            "text": "Start in the same place as Hasse var nära, then follow the roof straight out and up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-34": {
          "description": {
            "text": "Start as for Stjärt, then climb out where the roof extends furthest. Make a dynamic move out to the lip.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-35": {
          "description": {
            "text": "Start as for Stjärt, then climb left beneath the roof and up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-36": {
          "description": {
            "text": "Start with both hands on the flake. The problem finishes when you are standing on the ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-37": {
          "description": {
            "text": "Start beneath the roof and climb straight out over it.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-38": {
          "description": {
            "text": "Start as for Storebror, then climb left and up the crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-39": {
          "description": {
            "text": "Follow Mars 99, but continue left and then follow the arete up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-40": {
          "description": {
            "text": "Sit-start, then follow the obvious crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        },
        "nolby-bimbo-problem-41": {
          "description": {
            "text": "Sit-start and climb straight up to the right of Rövsmör.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:nolby-bimbo"
            ]
          }
        }
      }
    }
  }
}
