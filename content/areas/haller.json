            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "description": {
          "title": {
            "text": "Description",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          },
          "body": {
            "text": "One of Sweden’s premier trad crags. Classic crack and face climbing on fine-grained granite of exceptional quality. There are a few bolted routes, but the local climbing club and the Scandinavian climbing communities want no new bolts at Häller.\n\nPlease follow Bohuslän Climbing Club’s policy that the crag should remain bolt-free in future.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "directions": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          },
          "body": {
            "text": "From the E6, take road 162 towards Lysekil. Häller can be seen from the road a few kilometres after passing Hallinden. Follow signs towards Bro kyrka. Do not follow the old sign pointing to “Häller”; instead, take Vrångebäcksvägen 100 m further south. Drive for one kilometre along Vrångebäcksvägen, then drive up to the farm immediately below the crag. Pay SEK 20 for parking. If the car park is full, consider going elsewhere or park down by the main road.\n\nPlease read the access notes above.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "season": {
          "title": {
            "text": "Season",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          },
          "body": {
            "text": "March–November.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "nuts-and-bolts": {
          "title": {
            "text": "Protection",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          },
          "body": {
            "text": "Most routes are well protected with a standard trad rack. If the grade is followed by an “R”, the route is somewhat risky; if it is followed by an “X”, a fall from the crux may well be fatal.\n\nSome X-rated routes are protected using aid gear.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        }
      },
