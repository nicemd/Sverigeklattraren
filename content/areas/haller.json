        "haller-led-4": {
          "description": {
            "text": "Starts in the corner beneath the large roof right of Walk The Line. An exciting journey beneath the roofs and up to the ledge (7-) (belay, twin ropes or looong slings). Continue up the superb corner (7-) to the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "haller-led-5": {
          "description": {
            "text": "Starts as for Tydliga Hörnet, then goes straight up the arete.",
