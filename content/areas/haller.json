            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "haller-led-14": {
          "description": {
            "text": "Starts as for Klart Svår, then heads right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "haller-led-15": {
          "description": {
            "text": "Follow a thin crack system straight up to the end of the first roof traverse on Tre Tau. Follow the corner for 5 m, then move left onto the slab at the next roof. A little way up, a little left, difficult moves up, then back right. Stay on the slab throughout. Finally, climb onto the large ledge. Finish straight up from the block via the overhanging corner, 7 m. Birdbeaks, skyhooks, sliding nuts and small RPs help keep the nerves in check.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "haller-led-16": {
          "description": {
            "text": "Starts right of the pool.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:haller"
            ]
          }
        },
        "haller-led-17": {
          "description": {
            "text": "Climb up to and past the obvious, superb crack. Then traverse right to a large ledge.",
            "method": "llm",
