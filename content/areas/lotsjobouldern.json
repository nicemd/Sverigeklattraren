      "routes": {
        "lotsjobouldern-problem-1": {
          "description": {
            "text": "Left hand starts on the block to the left, right hand in the undercling. Climb straight up the wall. Finish at the first ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-2": {
          "description": {
            "text": "Straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-3": {
          "description": {
            "text": "Straight up, with an awkward start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-4": {
          "description": {
            "text": "Start with both hands in the drill hole. The left edge of the slab to the left is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-5": {
          "description": {
            "text": "Start with both hands in the obvious vertical crack/flake and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-6": {
          "description": {
            "text": "The brown block to the right is out, as are the crack/flake to the left and everything left of it.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-7": {
