            ]
          }
        },
        "lotsjobouldern-problem-8": {
          "description": {
            "text": "Straight up the far-right arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:lotsjobouldern"
            ]
          }
        },
        "lotsjobouldern-problem-9": {
          "description": {
            "text": "Start on the obvious hold in the middle of the wall. Climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
