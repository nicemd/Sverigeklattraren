            "text": "Left Sector",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tumbo"
            ]
          },
          "body": {
            "text": "Four fives and an anchor. Furthest left on the wall. Here the sun shines in good weather.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
