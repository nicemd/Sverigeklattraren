            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-34": {
          "description": {
            "text": "7B sit-start. 7A+ stand-start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-35": {
          "description": {
            "text": "Starts on the same rail as Really Mad Hooker and Really Bad Hooker. Then climbs up left into Kristi brud.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-38": {
          "description": {
            "text": "Jump start, then straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-39": {
          "description": {
            "text": "High start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-40": {
          "description": {
            "text": "Follows the arête to the right of Lynx Lynx.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-41": {
          "description": {
            "text": "Starts at the very back of the cave.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
