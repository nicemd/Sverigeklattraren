          "description": {
            "text": "A decent stand-start on the lowest rock. On the overhanging wall 70 metres east of the Mad Hooker boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
