          "description": {
            "text": "Sit-start slightly right of Djurperken. Join it via its right-hand crimp.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-44": {
          "description": {
            "text": "Follow the right arête of the Mad Hooker overhang. High top-out, the same as Bad Hooker.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
