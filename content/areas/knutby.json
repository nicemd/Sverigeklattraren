  "translations": {
    "en": {
      "description": {
        "text": "=Problems=",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:knutby"
        ]
      },
      "sections": {},
      "routes": {
        "knutby-problem-1": {
          "description": {
            "text": "The problem starts in the middle of the overhang on the Kristi-Brud boulder. It then trends left and tops out on the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-2": {
          "description": {
            "text": "A slightly taller slab with the crux near the top. To the right of Fet,ful och fattig.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-3": {
          "description": {
            "text": "Straight up, to the right of Henke Lycklig.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-4": {
          "description": {
            "text": "Straight up, to the right of Månskäran.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-5": {
          "description": {
            "text": "Straight up via the obvious crescent-shaped hold.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-6": {
          "description": {
            "text": "Starts as Mad Hooker, then trends slightly right via the high crimps. Tops out straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-7": {
          "description": {
            "text": "Straight up, trending right from the small crimps.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-8": {
          "description": {
            "text": "Start with your right hand on a Duella hold and your left on another crimp. Then climb diagonally up left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-9": {
          "description": {
            "text": "Straight up over the bulge on the N boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-10": {
          "description": {
            "text": "Starts as Meles meles, then climbs diagonally up right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-11": {
          "description": {
            "text": "Straight up along the left arête of the A boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-12": {
          "description": {
            "text": "A long throw from two pockets (hand and mono) to an edge. Then straight up without using the arête on the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-13": {
          "description": {
            "text": "The easiest way up. I started on the right beside the trad route and topped out on the slab above and to the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-14": {
          "description": {
            "text": "Start a couple of metres left of Aktiv grävling on the obvious holds. Climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-15": {
          "description": {
            "text": "Sit-start to Mad Hooker. Start with both hands on the lowest rail.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-16": {
          "description": {
            "text": "On the same boulder as Lynx Lynx. The left side of the far arête.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-17": {
          "description": {
            "text": "Starts low on the ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-19": {
          "description": {
            "text": "Start on the arête, then follow the edge left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-20": {
          "description": {
            "text": "Start on the arête, then climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-21": {
          "description": {
            "text": "Starts on the triangular hold in the overhang, with a crimp for the right hand, then climbs straight up. (Warning: loose hold)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-22": {
          "description": {
            "text": "Hard first move.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-23": {
          "description": {
            "text": "Starts on a jug, then climbs straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
