        "knutby-problem-45": {
          "description": {
            "text": "Starts as Prize Cut, then climbs straight up the vertical wall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-46": {
          "description": {
            "text": "Starts by Leif-Edvin. Straight up the slab face.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-47": {
          "description": {
            "text": "Between \"Livsfarlig att leda\" and \"Fet, ful och fattig\".",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-48": {
          "description": {
            "text": "Follows the left arête of the Mad Hooker overhang.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-49": {
          "description": {
            "text": "At the far left of the slab face.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-50": {
          "description": {
            "text": "Right hand on a large layback hold, then diagonally left towards a jug.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-52": {
          "description": {
            "text": "Slab groove.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-53": {
          "description": {
            "text": "Over the slabby rib to the left of Huggorm.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-54": {
          "description": {
            "text": "Starts on the small holds below Kristibrud.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-55": {
          "description": {
            "text": "Climbs the right arête on the back of the kollosos boulder. Stand-start on slopers, then follow the arête up left. A sit-start could be worked out for anyone keen.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-56": {
          "description": {
            "text": "On the M boulder in Föraren, no. 5.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        }
