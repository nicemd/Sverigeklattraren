            "text": "Sit-start to Bad Hooker. Start with both hands on the lowest rail directly below Mad Hooker.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
