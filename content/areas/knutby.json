          "description": {
            "text": "Starts to the right of the arête.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
        "knutby-problem-32": {
          "description": {
            "text": "Sit-start to the problem that climbs over the ‘nose’ on the same boulder as Mount Knutby. Hard moves on slopers to reach the stand-start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knutby"
            ]
          }
        },
