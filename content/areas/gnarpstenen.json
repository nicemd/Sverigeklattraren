            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-6": {
          "description": {
            "text": "Sit start beneath the lowest edge of the Hyena boulder. Lunge to the lip and mantle.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-7": {
          "description": {
            "text": "Sit start on the right-hand side of the overhang on the other boulder, 5 m behind Minstingen. The aretes are excluded.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-8": {
          "description": {
            "text": "Sit start beneath the crack, 2 m left of Minstingen.",
