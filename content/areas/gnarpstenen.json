        "gnarpstenen-problem-1": {
          "description": {
            "text": "Sit start by the arete, move right via the flake, then climb up by the crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-2": {
          "description": {
            "text": "Sit start with hands on the edges and climb straight up. Finishes on the jug at the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-3": {
          "description": {
            "text": "Sit start with hands in the crack, then climb straight up. A balance crux. Finishes with hands on the jug.",
