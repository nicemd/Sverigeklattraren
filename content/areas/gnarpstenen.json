            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-11": {
          "description": {
            "text": "Starts as for Dingo, then climbs straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
