            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-9": {
          "description": {
            "text": "Sit start with hands on the ramp, continue to the flake out left, then climb up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:gnarpstenen"
            ]
          }
        },
        "gnarpstenen-problem-10": {
          "description": {
            "text": "Starts as for Dingo, crosses Hyena, then climbs the arete.",
