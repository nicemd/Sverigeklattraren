  "translations": {
    "en": {
      "description": {
        "text": "=Directions= Drive north along the old E4. Turn off towards Eskön and Hillevik. Just before reaching Eskön, there is a sign saying “ESKÖRÖNNINGEN”; turn left here. Drive past several small houses until you reach a large open area on the left. Park here. Walk towards the woods, where you will see a nature trail. Just before the nature trail, there is a small path on the right. Follow it down towards the water and keep left when you reach the shoreline. After a couple of hundred metres, you will see a long slab on your left. This is where the area begins. =Problems=",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:eskoronningen"
        ]
      },
      "sections": {},
      "routes": {
        "eskoronningen-problem-3": {
          "description": {
            "text": "Establish with your left hand on the undercling.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-4": {
          "description": {
            "text": "On the same wall as Isis (the steep wall). Start on the crimps and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-5": {
          "description": {
            "text": "On the Butterfly boulder. Start with your left hand on the low sidepull and your right hand on the edge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-6": {
          "description": {
            "text": "On the boulder opposite Willy Wonka, near the Butterfly boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-7": {
          "description": {
            "text": "On the same boulder as Silly (Fontainebleau-style slopers). Traverse left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-8": {
          "description": {
            "text": "On the Aladdin wall. Start with your left hand on the sidepull crimp and your right hand on the small crimp.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-9": {
          "description": {
            "text": "A fine problem.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-10": {
          "description": {
            "text": "On the same boulder as Zeitgeist. Straight up the right-hand arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-11": {
          "description": {
            "text": "Start underneath the boulder and follow the arete straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-12": {
          "description": {
            "text": "The boulder is where the walls end. Follow the wall uphill towards the woods.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-13": {
          "description": {
            "text": "Traverse the entire boulder leftwards, starting at the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-14": {
          "description": {
            "text": "Straight up. On the same boulder as Kosmologen.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-15": {
          "description": {
            "text": "Start underneath the boulder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-16": {
          "description": {
            "text": "On the Butterfly boulder. Start on the marked holds beneath the roof.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-17": {
          "description": {
            "text": "On the same boulder as 11år sen sist, at the far left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-18": {
          "description": {
            "text": "A very balancey problem on a boulder to the left of the good warm-up boulder in the middle of the area.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        },
        "eskoronningen-problem-19": {
          "description": {
            "text": "Sit start on the obvious holds beneath the roof, then climb straight up without going round the arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:eskoronningen"
            ]
          }
        }
      }
    }
