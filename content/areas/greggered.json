        "greggered-led-14": {
          "description": {
            "text": "Start in front of the tree, climb the left-leaning hand-jam crack, traverse 45cm, then follow the next left-leaning hand crack to the ledge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:greggered"
            ]
          }
        },
        "greggered-led-15": {
          "description": {
            "text": "There is a single bolt four metres left of Hans's anchor. Jens calls it a top-rope anchor, and it gives three routes graded 6a, 6b and 6b.",
