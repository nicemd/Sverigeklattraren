      "routes": {
        "jagarhyddan-rimbo-problem-1": {
          "description": {
            "text": "Follow the prominent crack system up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-2": {
          "description": {
            "text": "Sit start 2 m left of Diskussprickan and traverse left to right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-3": {
          "description": {
            "text": "On the side of the boulder facing the discus ring. Follow the obvious crack up. Slightly harder from a sit start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-4": {
          "description": {
            "text": "Start in Diskussprickan and follow the line diagonally up right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-5": {
          "description": {
            "text": "Traverse the crack from left to right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-6": {
          "description": {
            "text": "Traverse the crack from left to right, finishing established at the crack of Granitlinjen.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-7": {
          "description": {
            "text": "Straight up the compact crack system.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-8": {
          "description": {
            "text": "Climb Harkrankstraversen and link it into Granitlinjen.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-9": {
          "description": {
            "text": "The leaning pillar facing north.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-10": {
          "description": {
            "text": "Start on the obvious crimps, match the sloper and climb up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-11": {
          "description": {
            "text": "Start as for Unknown Pleasures, then head up right after the sloper.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-12": {
          "description": {
            "text": "Start beneath Bananen, follow the crack line and finish as for Hallinskide/Unknown Pleasures.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-13": {
          "description": {
            "text": "Start on Hallinskide, traverse right and finish as for Fågelsång.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-14": {
          "description": {
            "text": "Climb the banana-shaped corner, finishing with both hands on top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-15": {
          "description": {
            "text": "Use only the pink-coloured sections of the banana-shaped corner.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-16": {
          "description": {
            "text": "Climb the outer edge of the second corner.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-17": {
          "description": {
            "text": "Start at the corner and follow the crack line right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
