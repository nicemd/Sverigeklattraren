          "description": {
            "text": "Myggtraversen from a sit start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
        "jagarhyddan-rimbo-problem-19": {
          "description": {
            "text": "Straight up the compact wall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
