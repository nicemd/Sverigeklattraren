          "description": {
            "text": "Start on the crimps, take the pink crimp with your right hand, then catch the hold straight above.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:jagarhyddan-rimbo"
            ]
          }
        },
