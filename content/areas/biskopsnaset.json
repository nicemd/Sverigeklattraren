  "translations": {
    "en": {
      "description": {
        "text": "=General= A welcome addition to the Ludvika bouldering scene. The \"area\" consists of a single but excellent boulder close to town. The guide is not yet complete; more problems have been climbed and will hopefully be added here shortly. Please help refine the grades!\n\n=Directions= Take Näsvägen out onto Biskopsnäset and park at the obvious widening in the road by the small clear-cut area. Make sure to leave enough room for the cottage owners. Take the path out to the track and follow it south. Cross to the other side of the track when possible and continue south. At the 1.5 km sign, turn off towards the lake to reach the boulder.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:biskopsnaset"
        ]
      },
