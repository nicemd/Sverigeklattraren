      "routes": {
        "biskopsnaset-problem-1": {
          "description": {
            "text": "A little trickier than it looks. Can be climbed in either direction. Blue line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-2": {
          "description": {
            "text": "Catch moves on comfortable sloping ledges. The holds to the left are not part of the problem. For the variant \"Återfall\", 6A, catch with the right hand. \"Off the Wagon\", 6A+, is the same problem without the upper sloping ledge. Orange line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-3": {
          "description": {
            "text": "Sit start at the diagonal crimps. Climb straight up. Green line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-4": {
          "description": {
            "text": "Low start from crimps in the horizontal crack. Catch up left to a jug in the crack. Right of the green line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-5": {
          "description": {
            "text": "Low start/sit start far out right on the sloping ledge. Orange line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-6": {
          "description": {
            "text": "Sit start at the arete. The good pinch is best used as the starting hold for the left hand. Orange line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-7": {
          "description": {
            "text": "Starts with the sit start of Hemma. Traverse left and finish with Bakåtfall.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-8": {
          "description": {
            "text": "Sit start on good holds beneath the overhang. Climb diagonally up across the arete to top out. Blue line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-9": {
          "description": {
            "text": "Straight up at the overhang. Red line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-10": {
          "description": {
            "text": "Sit start on good holds beneath the overhang. Climb straight up. Red line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-11": {
          "description": {
            "text": "Standing start from crimps. Climb diagonally up left, then continue straight up via the large holds. Blue line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-12": {
          "description": {
            "text": "Alternative start to Lugna sig lite. Establish yourself/sit start low and left of the large holds, then climb into the blue line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-13": {
          "description": {
            "text": "Standing start from the \"nose\", then straight up. Orange line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-14": {
          "description": {
            "text": "Sit start from the good crimp beneath the ramp. The top of the ramp is out. Orange line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-15": {
          "description": {
            "text": "Sit start on the good holds. Climb left, then continue upwards from the undercut. Blue line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:biskopsnaset"
            ]
          }
        },
        "biskopsnaset-problem-16": {
          "description": {
            "text": "Sit start on the good holds. Move right to the arete, then continue straight up the left-hand corner. Orange line.",
            "method": "llm",
