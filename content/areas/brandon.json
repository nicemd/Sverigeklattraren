      "sections": {},
      "routes": {
        "brandon-problem-1": {
          "description": {
            "text": "Right of no. 51. Straight up without using the arete!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-2": {
          "description": {
            "text": "Right of Hustler V.I.P. Standing start one metre left of the large crack. Straight up. Anything goes! Start on two obvious edges. Climb up and mantle. The crack to the right is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-3": {
          "description": {
            "text": "Straight up by the arete to the right of the Finns' problem.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-4": {
          "description": {
            "text": "Match the starting jug and make a long move out left. The right arete is out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-5": {
          "description": {
            "text": "Start on the same edge as Snatch, but go straight up to the lip instead.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-6": {
          "description": {
            "text": "Sit start left of Hustler V.I.P on two obvious crimps, then traverse right and mantle out via Scouten från Avafors.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-7": {
          "description": {
            "text": "Start on the obvious edge, then catch right!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-9": {
          "description": {
            "text": "Straight up and top out!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-11": {
          "description": {
            "text": "The crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brandon"
            ]
          }
        },
        "brandon-problem-14": {
