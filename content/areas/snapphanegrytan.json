  "translations": {
    "en": {
      "description": {
        "text": "The crag is situated on Hallandsåsen, between Skåne and Halland. It is 6–10 m high, with excellent friction and plenty of fine jamming, so bring cams or hexes. There are currently 12 routes. After rain, the routes need a couple of days of dry weather before they dry out.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:snapphanegrytan"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:snapphanegrytan"
            ]
          },
          "body": {
            "text": "The crag is situated on Hallandsåsen between Skåne and Halland. It is 6–10 m high, has excellent friction and offers plenty of fine jamming, so it is worth bringing cams or hexes. There are currently 12 routes. After rain, the routes need a couple of dry days before they dry out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:snapphanegrytan"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:snapphanegrytan"
            ]
          },
          "body": {
            "text": "Map here. Click the map button above.\n\nDirections: leave the E6 at Hjärnarp and continue towards Ugglehult/Lerbäckshult. Drive past Faxeröd; the tarmac soon turns to gravel. Pass the road to djurholmen, continue for 1 km, then take the road on the left and follow it for about 2 km. A cottage and lake appear on the right; a few hundred metres further on, kolugnsvägen is on the right. Park here and walk the final 300 m along Kolungnsvägen. The crag can be seen on the left, 40 m into the woods.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:snapphanegrytan"
            ]
          }
        },
