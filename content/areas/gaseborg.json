    {
      "id": "gaseborg-led-55",
      "kind": "route",
      "number": null,
      "name": "Inga fler kratrar",
      "grade": "6c+",
      "length": "10",
      "type": "sport",
      "firstAscent": "Anders Grahne, Andreas Harne -06",
      "description": "Leden startar precis vid en inristning i berget; \"Till minne av...\" ca en meter t v om insteget till Wall Hall. Den fortsätter på svat/platten ca 1- 1,5 m v om Wall Hall hela vägen (utan att tangera den) upp till tallen. Går man ut till kanten som man har ett par m på v sida blir leden betydligt enklare. Leden lättar av när man passerat kruxet efter andra bulten, men håller en kvalitativ klättring hela vägen upp. En lite rakare, finare linje än Wall Hall och betydligt känsligare för fötter och fingrar.",
      "sectorId": "djavulsvaggen",
      "source": {
        "id": "legacy:gaseborg",
        "path": "mediawiki/Gåseborg.txt"
      }
    },
