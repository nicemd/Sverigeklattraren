    {
      "id": "gaseborg-led-54",
      "kind": "route",
      "number": null,
      "name": "Solnedgången",
      "grade": "5-",
      "length": "10",
      "type": "trad",
      "firstAscent": "Sven Blom -82",
      "description": "Börjar på vänster sida om kanten. Traditionellt säkrad, inga bultar (de tillhör \"Inga fler Kratrar\".)",
      "sectorId": "djavulsvaggen",
      "source": {
