            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:runsastenen"
            ]
          },
          "body": {
            "text": "Follow the signposted road towards Runsa for about 6 km. Park in the car park after the avenue. Follow the gravel road for about 400 m to the sign for Runsaborg pointing left. Follow the path. After about 200 m, the boulder is clearly visible on the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
