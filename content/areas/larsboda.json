  "translations": {
    "en": {
      "description": {
        "text": "The crag is in an open setting beside a footpath and has a few problems, a couple of which are really good. Fridge-klippan is the main attraction, although a couple of other crags are listed in the old guide. At least one of the other crags (Crack for kids) is no longer accessible.\n\nThe area was developed mainly by Stefan Pettersson many years ago...",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:larsboda"
        ]
      },
