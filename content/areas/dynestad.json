            "text": "Guidebook",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "A guide produced by Västervik Climbing can be found at www.vastervikclimbing.se (http://www.vastervikclimbing.se/klattercentret/pdfer/).",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          }
        }
