  "translations": {
    "en": {
      "description": {
        "text": "Dynestad offers vertical and overhanging climbing on walls up to 18 m high. A very pleasant crag in a beautiful setting, which we highly recommend. The climbing is on solid granite, sometimes split by cracks. Stone was quarried at Dynestad in the late 19th century. Several of the routes are of exceptionally high quality. This is one of the best sport climbing crags we have. There are challenges at a range of grades for all climbers. The wall faces south and gets the sun from around 10.00. It dries relatively quickly after rain and is a good spring crag. The crag has 12 particularly recommended routes.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:dynestad"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "Dynestad offers vertical and overhanging climbing on walls up to 18 m high. A very pleasant crag in a lovely setting, which we highly recommend. The climbing is on solid granite, though it is sometimes fractured. Stone was quarried at Dynestad in the late 19th century. Several of the routes are of very high quality. This is one of our best sport climbing crags. There are challenges at a range of grades for all climbers. The wall faces south and gets the sun from around 10.00. It dries relatively quickly after rain. A good spring crag. The crag has 12 particularly recommended routes.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "The crag lies about 25 km north of Västervik. Leave the E22 at the northern exit towards Gamleby centre and continue for 1 km. Turn left at the square, drive past the folk high school and stop after 1 km. Immediately after a small bridge, turn right into the car park. Then follow the path south for 700 m, with Dynestadsviken on your right. The crag is visible on the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          }
        },
        "overnattning": {
          "title": {
            "text": "Accommodation",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "KustCamp campsite at Hammarsbadet is 2 km from Gamleby centre, tel. 0493-10221, www.campa.se (http://www.campa.se)\n\nÖverums hostel, tel. 0493-30302, www.overum.nu (http://www.overum.nu/),\n\ncabins and camping at Risebo fritid, tel. 0493-33046, www.risebofritid.se (http://www.risebofritid.se),\n\ncamping and cabins are available at Lysingsbadet in Västervik, tel. 0490-258000, www.lysingsbadet.se (http://www.lysingsbadet.se),\n\ncabins are available at Tofvehults café och konferens, tel. 0490-26351, www.tofvehult.se (http://www.tofvehult.se), and at\n\nLive in Nature at Kallersnäs gård, tel. 0768-513090, www.liveinnature.se (http://www.liveinnature.se)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          }
        },
        "affarer": {
          "title": {
            "text": "Shops",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "The nearest grocery shop, ICA, is in Gamleby centre, about 2 km from the crag. The nearest petrol stations, Bilia and Preem, are in Gamleby.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          }
        },
        "klattercenter": {
          "title": {
            "text": "Climbing Centre",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "The meeting place for climbers is the centre in Västervik, at Repslagargatan 5 by the old water tower. Free wireless internet is available, or you can borrow a computer. It is a place to meet, share experiences, read climbing magazines, watch climbing films and get up-to-date information about climbing and other activities in the municipality. It is also a place where you can climb indoors and get to know other climbers. Call 0490-37466 for more information.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:dynestad"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
