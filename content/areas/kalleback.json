  "translations": {
    "en": {
      "description": {
        "text": "A small crag close to a care home. If you are a student living in the area (Kallebäck), you may fancy climbing here. Top-ropes are easy to set up using the large trees.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:kalleback"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          },
          "body": {
            "text": "A small crag close to a care home. If you are a student living in the area (Kallebäck), you might fancy climbing here. Top-ropes are easy to set up using the large trees.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          }
        },
        "parkering": {
          "title": {
            "text": "Parking",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          },
          "body": {
            "text": "Park by the care home, walk into the woods and look out for a small crag on the right. Of little interest to experienced climbers, as all the routes are at the very low end of the grade range. Slab.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          }
        },
        "forsta-klippan": {
          "title": {
            "text": "First crag",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          },
          "body": {
            "text": "Plenty of ticks guaranteed. There is potential to brush out a couple of new routes. The crag is about 10 metres high. FA: Patrik Alsebyg and Mattias Järemo, 1991, for most of the routes.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          }
        },
        "andra-sidan": {
          "title": {
            "text": "Other side",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kalleback"
            ]
          }
        }
      },
