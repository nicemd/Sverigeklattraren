  "translations": {
    "en": {
      "description": {
        "text": "Knipehall is a crag approximately 100 metres wide and 15 metres high, beautifully situated in eastern Blekinge. Around 30 routes offer challenges across most grades. The rock is of very good quality and looks compact, but has a fair number of cracks. There is both sport and aid climbing, though the main focus is on trad. The easy routes at the far right are very mossy; elsewhere the rock is clean and in good condition.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:knipehall"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knipehall"
            ]
          },
          "body": {
            "text": "Knipehall is an approximately 100-metre-wide and 15-metre-high crag in a beautiful setting in eastern Blekinge. Around 30 routes offer challenges across most grades. The rock is very good quality and appears compact, but has a fair number of cracks. There are both sport and aid routes, but the main focus is trad climbing. The easy routes at the far right are very mossy; otherwise, the crag is clean and in good condition.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knipehall"
            ]
          }
        },
        "access": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knipehall"
            ]
          },
          "body": {
            "text": "The crag is quite close to a house to the north, and there are many boats by the jetties below. Karlskrona Bergsportförening has so far maintained a good dialogue with the homeowner, but climbers should of course keep a low profile here. If you want to establish a new route involving new bolts, Karlskrona Bergsportförening asks that you contact Patrik Lind (patrik.lind {snabela} ltblekinge.se) before any drilling is carried out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knipehall"
            ]
          }
        },
        "hitta-hit": {
          "title": {
            "text": "Getting there",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knipehall"
            ]
          },
          "body": {
            "text": "The crag is by the sea, approximately five kilometres east of Karlskrona. Take the E22 towards Kalmar and turn right towards Lösen kyrka/Fäjö. Immediately turn left towards Fäjö and follow the road all the way to the bridge to Fäjö. The crag is on the right just before the bridge.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:knipehall"
            ]
          }
        },
        "sodra-delen": {
          "title": {
            "text": "Southern section",
            "method": "llm",
