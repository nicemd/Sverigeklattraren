  "translations": {
    "en": {
      "description": {
        "text": "Norra Rörum is a small crag in central Skåne, 10 km north of Höör. The climbing is divided between two sections with slightly different characters. The east wall is steep and around 8 metres high, with crack and face climbing on plenty of small holds and edges. The south wall is more polished and slightly overhanging, offering some excellent balancey routes. Most of the climbing here is trad, though there are a number of bolts to clip. Top-rope anchors are usually easy to set up using trees if you have long slings or a static rope. The approach is easy, and access around the crag itself could hardly be better. The crag is in shade for virtually the whole day.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:norra-rorum"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          },
          "body": {
            "text": "Norra Rörum is a small crag in central Skåne, 10 km north of Höör. The climbing is split between two sections of wall with slightly different characters. The east wall is steep and about 8 metres high, with crack and face climbing on plenty of small holds and edges. The south wall is more polished and slightly overhanging, offering some excellent balance routes. The climbing here is mostly trad, though there are a number of bolts to clip. Top anchors can usually be built easily using trees if you have long slings or a static rope. The approach is easy, and access at the crag itself could hardly be better. The crag is in the shade for virtually the entire day.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "hitta-hit": {
          "title": {
            "text": "Getting there",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          },
          "body": {
            "text": "From Höör, drive north on road 23 towards Sösdala/Hässleholm. About 5 km after Höör, turn left towards Norra Rörum. Once in Norra Rörum, turn right in the centre of the village, by the village shop. Pass the church and continue out of the village, where the road runs between two large fields. Just where the fields end and the forest begins, with houses on the right, a small gravel road turns off to the left. Park at the start of this road, parking considerately. Walk west along the gravel road for about 50 metres, where there is a stile over the fence on the left. Cross the stile and walk straight across the meadow until you reach a gravel road on the other side; it is visible before you cross the meadow. Follow this gravel road to the right for about 200 m, passing a large pit on the left, until it meets another gravel road running north–south. Turn left and follow the road until you reach the crag and the turning area at the end of the road.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "vaggoversikt": {
          "title": {
            "text": "Wall overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          },
          "body": {
            "text": "• 1–3 South wall\n• 4–5 East wall\n• 6–8 Bouldering walls",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "sodra-vaggen": {
          "title": {
            "text": "South wall",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
