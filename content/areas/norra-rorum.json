      "routes": {
        "norra-rorum-led-1": {
          "description": {
            "text": "Easy climbing to the two parallel scoops. Poorly protected crux. Finish left of the branch. Risk of hitting the ledge!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-3": {
          "description": {
            "text": "An easy route up the less-than-impressive arete.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-4": {
          "description": {
            "text": "Start on the ledge, then trend right into the small corner.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-5": {
          "description": {
            "text": "Start in small cracks, then climb straight up broken rock. The exit via the crack on the left is the crux. Grade uncertain.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-6": {
          "description": {
            "text": "A direct-start variation to \"Myrslok\".",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-7": {
          "description": {
            "text": "Climb straight up to the first bolt. After the first bolt, trend slightly left and then continue straight up. One of the more enjoyable routes at Norra Rörum. Lower-off anchor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-8": {
          "description": {
            "text": "The same start as \"Myrslok\", but where \"Myrslok\" trends slightly left, this continues straight up to a slab crux. A fairly desperate crux. Lower-off anchor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-9": {
          "description": {
            "text": "Follow the prominent crack all the way. The rock is friable and may break if you fall onto nuts. Poorly protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-10": {
          "description": {
            "text": "Easy at first. Tricky and hard to onsight!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-11": {
          "description": {
            "text": "An enjoyable route in the middle of the wall. Supplement the bolts with nuts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-12": {
          "description": {
            "text": "Wall and crack climbing. Sparsely protected at first, but better towards the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-13": {
          "description": {
            "text": "Crux at the start, protected with nuts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-14": {
          "description": {
            "text": "Follows the right-hand corner of the wall. Sparsely protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-15": {
          "description": {
            "text": "Initially follows \"Baksprickan\" to about halfway, then trends left past a fine layback. Well protected with nuts and cams. Grade uncertain.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-16": {
          "description": {
            "text": "Follow the right-hand crack straight up. Well protected with nuts and cams.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-17": {
          "description": {
            "text": "Climb a thin crack on the small pillar. (The exact line is uncertain.)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-18": {
          "description": {
            "text": "An obvious, slightly zigzagging crack. Grade uncertain.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-19": {
          "description": {
            "text": "Wall climbing up the middle of the left-hand wall. Protected by one bolt.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-20": {
          "description": {
            "text": "A tough route to the right of \"Börnis bravader\". Very hard on the fingers and protected by two bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-21": {
          "description": {
            "text": "Strenuous wall climbing with a crux at the start and a second crux at the bolt, which is the only protection.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-22": {
          "description": {
            "text": "Follow the crack straight up to the flake that trends left. Sparsely protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-23": {
          "description": {
            "text": "Follow the crack to the right. Crux at the top-out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-24": {
          "description": {
            "text": "Straight up the right-hand side of the wall. Shares the top-out of \"Raka rör\", which is also the crux.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-26": {
          "description": {
            "text": "Straight up the rock, to the right of the small corner.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-27": {
          "description": {
            "text": "Starts a metre or so from the corner, with a hard catch before the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-28": {
          "description": {
            "text": "Traverse the lower part of the rock.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-29": {
          "description": {
            "text": "A strenuous traverse back and forth just above the ground. Slightly overhanging.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        },
        "norra-rorum-led-30": {
          "description": {
            "text": "Straight up the clean section on the right-hand side of the rock.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:norra-rorum"
            ]
          }
        }
      }
    }
  }
}
