  "translations": {
    "en": {
      "description": {
        "text": "A small, steep crag about 1 km south of Skogås commuter railway station. It is 10–14 m high and has a number of fairly short, though in some cases quite good, routes. Numerous old military fortifications provide a few surprises. Unfortunately, the crag is fairly litter-strewn due to its proximity to the residential area. It is not too bad, though, but this is not a great crag for crawling children or dogs because of some broken glass.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:sjotorpsberget"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          },
          "body": {
            "text": "A small, steep crag about 1 km south of Skogås commuter railway station. It is 10–14 m high and has several fairly short, but in some cases quite good, routes. Numerous old military fortifications offer a few surprises. Unfortunately, its proximity to the residential area means there is quite a lot of litter. It is not too bad, but because of some broken glass, this is not a great crag for crawling children or dogs.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "miljo": {
          "title": {
            "text": "Aspect",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          },
          "body": {
            "text": "South-facing but partly shaded.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          },
          "body": {
            "text": "Take Nynäsvägen to the Skogås exit and continue towards Skogås. About 400 m after the railway, turn right onto Rapsodivägen and park at the turning for Rapsodivägen 272–378. Continue down the turning to the footpath and turn left.\n\nParking on Rapsodivägen may result in a parking fine, as the residents’ association has made these spaces residents-only. An alternative is to continue straight ahead along Österleden instead of turning onto Radsodivägen. Drive to the end and park. This avoids all the restriction signs that abound in the area. Walk down to the water and follow the pleasant path to the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "kommunikationer": {
          "title": {
            "text": "Public transport",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          },
          "body": {
            "text": "After getting off the commuter train at Skogås, walk south along the railway through the residential area. After a steep hill, the paved path descends to a narrow gravel road. The crag is about 100 m to the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "extern-forare": {
          "title": {
            "text": "External guide",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          },
          "body": {
            "text": "A guide is available on Stockholms Nätförare (http://www.plonk.se/snf/sjotorpberget.html).",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        }
      },
      "routes": {
        "sjotorpsberget-led-3": {
          "description": {
            "text": "Shares the start with 1/1a, then goes straight up past two bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-5": {
          "description": {
            "text": "New route on the slabby section between Smutsrännan and Dubbeltaket. It tends to feel a bit unpleasant... Try it and see.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-10": {
          "description": {
            "text": "“Starts” beneath the roof; reach the start via 6.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-12": {
          "description": {
            "text": "Bolt line to the left of häng loss.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-17": {
          "description": {
            "text": "Missing hangers?",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-19": {
          "description": {
            "text": "Delicate and slightly overhanging.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-20": {
          "description": {
            "text": "Branches right over the bulge and now joins the anchor on Glöm din dröm, if you want something to lower off from.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-22": {
          "description": {
            "text": "New route that lay hidden beneath the moss to the right of Kalaspuffen, before Mister Twister.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-23": {
          "description": {
            "text": "Through the roof to the left of Mr Grotesh. It has lost a key starting hold and may be harder now. 4 bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-24": {
          "description": {
            "text": "Steeply overhanging climbing on big holds.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-25": {
          "description": {
            "text": "An extra bolt has been placed to the right of the first bolt, where the rock quality is better.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-26": {
          "description": {
            "text": "Right of Casall. Starts at the large flake. Shares an anchor with Casall. 6 bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-27": {
          "description": {
            "text": "Starts halfway along the flake and goes straight up to its own anchor. Can be a little loose. 7 bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-28": {
          "description": {
            "text": "Rebolted in -09 and fitted with a new anchor.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-29": {
          "description": {
            "text": "Through the roof between 15 and 16.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-30": {
          "description": {
            "text": "The crag’s warm-up route.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-33": {
          "description": {
            "text": "Vertical wall to the left of Ramaskri. 5 bolts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        },
        "sjotorpsberget-led-34": {
          "description": {
            "text": "Corner at the far right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:sjotorpsberget"
            ]
          }
        }
      }
    }
  }
