      "routes": {
        "hedesunda-problem-1": {
          "description": {
            "text": "The Landa boulders. The overhanging arete between the largest boulders.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-2": {
          "description": {
            "text": "The Landa boulders. A burly sit-start extension to Wayland.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-3": {
          "description": {
            "text": "The Landa boulders. Sit-start the low arete on the largest boulder. (Variant: do not use the holds to the left, 6C.)",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-4": {
          "description": {
            "text": "The Landa boulders. The fine wall right of the tree by Tommy Boy.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-5": {
          "description": {
            "text": "A sharp warm-up problem. Start sitting beneath the roof where the lower boulder is split, traverse around the left-hand corner and continue to the far end of the low wall. Top out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-6": {
          "description": {
            "text": "The easiest way up by the arete of the sugar-cube boulder. A super-cool, burly problem that may be harder.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-7": {
          "description": {
            "text": "A couple of metres right of Blade, straight up the wall on crimps.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-8": {
          "description": {
            "text": "The boulder by the bathing spot at Sandsnäs. Sit-start at the flake in the overhang, then climb up and right. Three stars once I have brushed it better...",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-9": {
          "description": {
            "text": "The arete by the small roof on the boulder in the clear-cut. Sit-start at the arete and trend diagonally beneath the roof, then climb up and mantle out left. Everything within reach from the arete is allowed. Fu, the standing start from holds beneath the roof, is 6B+.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-10": {
          "description": {
            "text": "The boulder in the clear-cut. Start with your hands on the ledge and mantle up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-11": {
          "description": {
            "text": "The left-hand arete on the boulder at the edge of the woods.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-12": {
          "description": {
            "text": "The boulder at the edge of the woods. Start at the crescent-shaped edge and climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-13": {
          "description": {
            "text": "The large boulder. Follow the green arrow up the slab on the side furthest from the road.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-14": {
          "description": {
            "text": "A small boulder at the edge of the woods, slightly further from the road. Sit-start from good holds on the slightly overhanging side.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        },
        "hedesunda-problem-15": {
          "description": {
            "text": "A low boulder, visible from the road near the parking. Sit-start at the ramp beneath the overhang.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hedesunda"
            ]
          }
        }
      }
    }
