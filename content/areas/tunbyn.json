  "translations": {
    "en": {
      "description": {
        "text": "A crag that offers sport, mixed, and trad climbing. The routes range from 10 to 20m, and there is potential for some really hard lines as the rock is extremely overhanging, living up to its nickname \"little Frankenjura.\"",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:tunbyn"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          },
          "body": {
            "text": "A crag offering sport, mixed, and trad routes. The climbs are between 10-20m long, with potential for some hard lines as the crag is extremely overhanging, justifying its nickname \"little Frankenjura.\"",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          },
          "body": {
            "text": "Take the exit from the E4 towards Matfors/Nolby. If coming from the south, this is just before Kvissleby. Drive through the village (Nolby) and continue for 8km. You will pass a gravel road on the right signposted to Alsta, and after about 200m, there’s a gravel parking area on the left. From there, follow the road on foot for another 200m, and the crag will be clearly visible on your right. Just before the road turns right, a small overgrown path leads in; follow this path up towards the crag.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          }
        },
        "camping": {
          "title": {
            "text": "Camping",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          },
          "body": {
            "text": "More information coming soon.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          }
        },
        "access": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          },
          "body": {
            "text": "Be mindful of nesting birds etc. to ensure access to the crag. Any felling of large or small trees, as well as undergrowth, is prohibited without first contacting the board of Sundsvall Climbing Club (http://www.sundsvallsklatterklubb.se). For more information regarding access and bolting policy, see our website for procedures and regulations (http://www.sundsvallsklatterklubb.se/page.php?page=klubbinfo&subpage=access).",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tunbyn"
            ]
          }
        },
        "leder": {
