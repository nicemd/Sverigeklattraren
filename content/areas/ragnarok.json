  "translations": {
    "en": {
      "description": {
        "text": "A fairly large area that is still being developed, with potential for around 50–100 problems in total. The views from some sectors are on a par with those at Nynäsboulderingen.\n\nThe distances are fairly large and some parts can be difficult to find, so compiling a complete guide will take time, but it is on its way, including photos. As mentioned, this is only a stub and a way of spreading out the work involved in producing a guide./c\n\nRagnarök OST (http://open.spotify.com/user/calleblingbling/playlist/5fdOC8MO46whkNGVrZUhag)\n\nRagnarök promo (http://vimeo.com/12158841)\n\nFor a preliminary, reasonably printable PDF guide, email calleblingbang at hotmail and it will be sent in reply.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:ragnarok"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A fairly large area that is still being developed. Potential for around 50–100 problems in total. The views from some sectors are on a par with the bouldering at Nynäs.\n\nThe distances are fairly large and parts can be difficult to find, so compiling a complete guide will take time, but one is coming, including photos. As mentioned, this is only a stub and a way of spreading out the work on the guide./c\n\nRagnarök OST (http://open.spotify.com/user/calleblingbling/playlist/5fdOC8MO46whkNGVrZUhag)\n\nRagnarök promo (http://vimeo.com/12158841)\n\nFor a preliminary and reasonably printable PDF guide, email calleblingbang at hotmail and it will be sent in reply.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Here and there",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "omraden": {
          "title": {
            "text": "Areas",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Rävberget is remote and about a 20-minute walk from the car park. Högaberget is the opposite, i.e. close by. The rock at Stenkvallen ranges from water-polished to flaky to sharp.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "hogaberget": {
          "title": {
            "text": "Högaberget",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Högaberget is high and extensive, so most of the sectors are found here.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "nasorna": {
          "title": {
            "text": "=Näsorna=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "An area with a short corridor and two ‘buns’, offering good, powerful lines.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "korridoren": {
          "title": {
            "text": "=Korridoren=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A narrow corridor, about 1.5 metres wide, with easy slabs on one side and slightly overhanging walls on the other. The landings tend to be quite wet during wetter periods. Plenty of mosquitoes in summer.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "roda-vagen": {
          "title": {
            "text": "=Röda Vågen=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Follow the hidden line in the direction of Korridoren. A large, beautiful red rock feature on the left, with potential for a looong traverse and a slightly risky-biznizz landing.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "kylskapet": {
          "title": {
            "text": "=Kylskåpet=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "This sector lies directly above Korridoren, beyond Röda Vågen. The hanging fridge is impossible to miss. Somewhat rocky landings.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "krypin": {
          "title": {
            "text": "=Krypin=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A difficult-to-find sector diagonally downhill from the middle of the crag. Short roof problems with good overhang. A long reach and some easy dynamic moves help.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "backen": {
          "title": {
            "text": "=Bäcken=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Everything from rather low problems to things that are a bit too high and really ought to be climbed on a rope.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "vatten-vaggen": {
          "title": {
            "text": "=Vatten Väggen=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Perhaps the nicest area in summer. Shady, lush deciduous woodland, about 10 metres from the water. Black, water-polished rock with good holds.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "fiskarfange": {
          "title": {
            "text": "=Fiskarfänge=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A low but good overhanging wall ending at an old abandoned fishing camp.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ravberget": {
          "title": {
            "text": "Rävberget",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A fox lives in the vicinity to the right of Grottan (hence the name), so please respect this and avoid moving around too much in that area. There are very often lots of wild boar moving around in the alder woods below, so late-night sessions here may not be advisable.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ravloungen": {
          "title": {
            "text": "=Rävloungen=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A 45-degree overhanging lip with potential for several lines, including a very good traverse on loaf-shaped pinches. ----",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "grottan": {
          "title": {
            "text": "=Grottan=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A fairly flaky but long, around 4–5 metres, and steep, around 45 degrees, overhanging roof with a large boulder wedged underneath. Perhaps 10–15 metres wide (minus 5–6 metres for the boulder), and around 4–5 metres high including the top-out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "hoxla": {
          "title": {
            "text": "Hoxla",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "An area beyond Högaberget, effectively a separate high crag...",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "gravlingsvaggen": {
          "title": {
            "text": "=Grävlingsväggen=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "An approximately 20-metre-wide wall of good height in a meadow setting. A faint scent of wild-animal musk.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "taxi-johan": {
          "title": {
            "text": "=Taxi Johan=",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A steep wall in awkward terrain just above ‘Taxi Johan’.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "det-bortanfor": {
          "title": {
            "text": "Det bortanför",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "Walls directly beside the water beyond Rävberget. Nicely exposed and sometimes really awkward to access.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "stugan": {
          "title": {
            "text": "Stugan",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          },
          "body": {
            "text": "A one-problem sector in a rather awkward location directly below a deck, so keep a very low profile if climbing here.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        }
      },
      "routes": {
        "ragnarok-problem-1": {
          "description": {
            "text": "Sit start. Follow the crack straight up and top out to the right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-2": {
          "description": {
            "text": "Sit start. Trend diagonally up left and mantle above the fork.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-3": {
          "description": {
            "text": "Sit start. Climb straight up on the right-hand side of the crack, without using the left side.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-4": {
          "description": {
            "text": "Standing start. Follow the crack up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-5": {
          "description": {
            "text": "Just above the corridor. Sit start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-6": {
          "description": {
            "text": "Green line. Climb up and right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-7": {
          "description": {
            "text": "Red line. Climb slightly rightwards.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-8": {
          "description": {
            "text": "Sit start.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-9": {
          "description": {
            "text": "Defined sit start on the pointed rock. Exposed climbing on the suspended fridge; a very fine and exposed line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:ragnarok"
            ]
          }
        },
        "ragnarok-problem-10": {
          "description": {
            "text": "Sit start on the sidepulls low in the cave. Top out using all holds.",
            "method": "llm",
