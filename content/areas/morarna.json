  "translations": {
    "en": {
      "description": {
        "text": "A steep and impressive crag beside the road to Skälåker on Gålö. The crag, which is up to about 20 m high, has a number of high-quality, difficult free-climbing routes. Nearest the road, the crag is steep with large, rounded features clearly shaped by the sea. A prominent corner separates this projecting section from the steep, smooth wall to the left.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:morarna"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:morarna"
            ]
          },
          "body": {
            "text": "A steep and impressive crag beside the road to Skälåker on Gålö. The crag, which is up to approximately 20 m high, has several high-quality, difficult free-climbing routes. Nearest the road, the crag is steep with large, rounded formations that have clearly been shaped by the sea. A prominent corner separates this projecting section from the steep, smooth wall to the left.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:morarna"
            ]
          }
        },
        "miljo": {
          "title": {
            "text": "Aspect and setting:",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:morarna"
            ]
          },
          "body": {
            "text": "West-facing and open to the sun. There are billions of ticks in the undergrowth!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:morarna"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:morarna"
            ]
          },
          "body": {
            "text": "Take Nynäshamnsvägen, turn off towards Dalarö and continue until you see a country shop on the right. Turn right towards Gålö, then after approximately 1 km turn left at the sign for Gålö havsbad and Skälåker. The crag is on the left after approximately 3 km. Turn into the car park by the ancient trail. The car park is on the left, just before the local heritage museum (red buildings on the right-hand side of the road).",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:morarna"
            ]
          }
        },
