  "translations": {
    "en": {
      "description": {
        "text": "The crag faces east and has 10 routes. It gets little sun but dries quickly after rain. The crag is 5–10 m high. Some of the routes are difficult to top out.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:manklippan-skedala"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          },
          "body": {
            "text": "The crag faces east and has 10 routes. It gets little sun but dries quickly after rain. The crag is 5–10m high. Some routes are difficult to top out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          },
          "body": {
            "text": "Map here. Tap the map button above.\n\nIt is easy to find from Solväggen: stand with your back to Solväggen and walk straight ahead for about 200m through the spruce forest until you reach a ravine. Descend into the ravine; from here you can see the crag on your right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "leder": {
