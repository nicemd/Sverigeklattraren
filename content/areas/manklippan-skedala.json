      "routes": {
        "manklippan-skedala-led-1": {
          "description": {
            "text": "Enjoyable, well-protected climbing, but short.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-2": {
          "description": {
            "text": "Start beneath the small roof, then climb straight up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-3": {
          "description": {
            "text": "A good route, though the top-out is a little awkward.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-4": {
          "description": {
            "text": "If you have nothing better to do, why not?",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-5": {
          "description": {
            "text": "Start traversing at the overhang and follow the crack system all the way right.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-6": {
          "description": {
            "text": "Climb the small corner, then exit left at the prominent edge before continuing straight up. Poorly protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-7": {
          "description": {
            "text": "The same start as Buxus, then straight up. Few protection opportunities and a difficult top-out.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-8": {
          "description": {
            "text": "A truly challenging, well-protected crack line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-9": {
          "description": {
            "text": "A fine line with cruxes midway up and at the top.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        },
        "manklippan-skedala-led-10": {
          "description": {
            "text": "For those who enjoy powerful reaches, though the top-out is a little tricky.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:manklippan-skedala"
            ]
          }
        }
      }
    }
