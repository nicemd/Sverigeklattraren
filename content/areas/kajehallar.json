        "kajehallar-led-4": {
          "description": {
            "text": "Never worked out how to finish it. The line is unclear in the Halmstad guidebook, but according to it the route has a “lovely finish”.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        },
        "kajehallar-led-5": {
          "description": {
            "text": "Nice laybacking up to the crux.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        },
        "kajehallar-led-9": {
          "description": {
            "text": "Nice full-body jam halfway up.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        },
        "kajehallar-led-10": {
          "description": {
            "text": "The first decent protection is 3 m up, beneath the flake.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        },
        "kajehallar-led-27": {
          "description": {
            "text": "Starts in the corner on the ledge left of Blåmes and follows the crack. Reasonably well protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        },
        "kajehallar-led-28": {
          "description": {
            "text": "Start on the ledge, climb straight up onto the flake (nice crack on the left), onto the plateau, then continue straight up the wall. The holds on the wall are better than they look.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        },
        "kajehallar-led-29": {
          "description": {
            "text": "Start on the ledge and follow the crack onto the plateau and into the chimney. Difficult to protect(?) before the plateau.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:kajehallar"
            ]
          }
        }
      }
