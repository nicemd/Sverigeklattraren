  "translations": {
    "en": {
      "description": {
        "text": "Outside Flatanger is a HUGE gneiss cave. There are routes both inside and outside the cave. Come here if you find Hell too easy!",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:flatanger"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "Outside Flatanger is a HUGE gneiss cave. There are routes both inside and outside the cave. Come here if you think Hell is too easy!",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "ovrigt": {
          "title": {
            "text": "Other information",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "Routes in the cave, known as Helleren, can be found on Headwall (http://www.headwall.com/headwall/explorer.jsp?cgy=CRAG&cid=374&skn=classic) and Steepstone (http://www.steepstone.com/topo/cragDet.asp?Crag_id=15).",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "leder": {
          "title": {
            "text": "Routes",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "hanshelleren": {
          "title": {
            "text": "Hanshelleren",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "The huge cave and the wall to its left. Approximately 100 m high, overhanging by 4–40 m.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "dalen-nedre-delen": {
          "title": {
            "text": "Dalen, Lower Section",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "A fairly long stretch of wall. Long sections have few obvious lines.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "dalen-midtre-del": {
          "title": {
            "text": "Dalen, Middle Section",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "It is worth bringing some larger protection. Several of the routes follow fairly wide cracks.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "dalen-ovre-del": {
          "title": {
            "text": "Dalen, Upper Section",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "oppvarmningsveggen": {
          "title": {
            "text": "Oppvarmningsveggen",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          },
          "body": {
            "text": "The routes often have serious and difficult starts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        }
      },
      "routes": {
        "flatanger-led-1": {
          "description": {
            "text": "Crack/corner. Starts in the left-hand corner, then joins the main corner.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:flatanger"
            ]
          }
        },
        "flatanger-led-2": {
          "description": {
            "text": "Shares a start with Trang födsel. Breaks right halfway up the first pitch.",
            "method": "llm",
