    {
      "id": "oppalaklippan",
      "title": "Oppalaklippan",
      "body": ""
    },
    {
      "id": "fire-away",
      "title": "Fire Away",
      "body": "För att komma till denna sektorn svänger du vänster mot Oppala i Björke. Efter ca 20m svänger du av till höger, följ denna väg förbi husen. Efter ca 1,5 km så ser du blocken på vänstersidan inne i skogen."
    },
    {
      "id": "hugo",
      "title": "Hugo",
      "body": "Sväng vänster vid Björke mot Oppala. Efter järnvägen ta första vägen till höger, parkera vid vändplanen. Blocken ligger i kullen rakt fram."
    },
    {
      "id": "linskakten",
      "title": "Linskäkten",
      "body": "Sväng vänster i Björke mot Oppala. Kör över järnvägen, när vägen gör en 90 grader sväng åt vänster ta av åt höger in på grusväg. Kör en knapp kilometer tills vägen svänger tvärt höger, sväng då av vänster (skylt Linskäkt). Första blocket finns ca 20m in till vänster."
    },
    {
      "id": "midgard",
      "title": "Midgård",
      "body": ""
    }
  ],
