  "translations": {
    "en": {
      "description": {
        "text": "From Linköping, take road 35 towards Åtvidaberg. Turn right towards Grebo. Before the village, turn right towards Norrby. Pass a red barn standing in the open, then after a few hundred metres park on a tractor track on the left in a small wooded area. Walk along the edge of the fields, then into the woods towards the lake. On reaching the lake, follow the shore to the right (northwards).",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:karingberget-grebo"
        ]
      },
      "sections": {
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:karingberget-grebo"
            ]
          },
          "body": {
            "text": "From Linköping, take road 35 towards Åtvidaberg. Turn right towards Grebo. Before the village, turn right towards Norrby. Pass a red barn standing in the open; after a few hundred metres, park on a forest track on the left in a small wooded area. Walk along the edges of the fields, then enter the woods and head towards the lake. At the lake, follow the shore to the right (northwards).",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:karingberget-grebo"
            ]
          }
        },
