  "translations": {
    "en": {
      "description": {
        "text": "Short, crimpy routes on vertical granite. Most of the routes are between 5b and 7a. There are fine views over Älvsbyn, also enjoyed by all the new couples cuddling at the top of the crag.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:hundberget"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hundberget"
            ]
          },
          "body": {
            "text": "Short, crimpy routes on vertical granite. Most routes are between 5b and 7a. There are fine views over Älvsbyn, also enjoyed by all the young couples cuddling at the top of the crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hundberget"
            ]
          }
        },
        "camping": {
          "title": {
            "text": "Camping",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hundberget"
            ]
          },
          "body": {
            "text": "It is possible to camp by the crag, but this is not recommended. Cabins can be rented in Älvsbyn.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hundberget"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hundberget"
            ]
          },
          "body": {
            "text": "From the Älvsby junction (Boden–Piteå–Älvsbyn–Vidsel), you can see Hundberget when looking towards Vidsel. Drive to the car park at the foot of the crag. Follow the path to the top. The climbing is on small walls at the top of the hill.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hundberget"
            ]
          }
        },
