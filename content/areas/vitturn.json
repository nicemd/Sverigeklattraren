  "translations": {
    "en": {
      "description": {
        "text": "Vitturn is located near the village of Klitten outside Älvdalen and is, despite its modest height of up to ten metres, one of Dalarna's finest sport crags thanks to its excellent rock quality (some quirky sandstone) and the lovely south-facing aspect atop a hill with stunning views, rivalled by few climbing venues in the country. It's a perfect crag for casual cragging on sunny summer evenings. Unfortunately, most of the anchors lack chains, but this will be addressed. The high and open south-facing location allows climbing from March to late October.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:vitturn"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "Overview",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:vitturn"
            ]
          },
          "body": {
            "text": "Vitturn lies by the village of Klitten outside Älvdalen and, despite its modest height of up to ten metres, is one of Dalarna's finest sport crags thanks to the excellent rock quality (some peculiar sandstone) and the lovely south-facing position atop a mountain with stunning views that few climbing crags in the country can match. It's a perfect crag for enjoyable picnic climbing on sunny summer evenings. Unfortunately, most anchors lack chains, but this will be addressed. The high and open south-facing position allows climbing from March to late October.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:vitturn"
            ]
          }
        },
        "vagbeskrivning": {
