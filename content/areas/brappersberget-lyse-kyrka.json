      "routes": {
        "brappersberget-lyse-kyrka-led-1": {
          "description": {
            "text": "Starts about 50 metres left of Amerikanskt fyrverkeri. Follow an obvious undercling band diagonally right to a ledge and belay. Then continue straight up a corner to the top. Excellent.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:brappersberget-lyse-kyrka"
            ]
          }
        },
        "brappersberget-lyse-kyrka-led-2": {
          "description": {
            "text": "Finger crack starting in a small overhanging corner, about 15 metres along the west wall.",
