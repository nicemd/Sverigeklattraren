            "sourceIds": [
              "legacy:brappersberget-lyse-kyrka"
            ]
          }
        },
        "brappersberget-lyse-kyrka-led-3": {
          "description": {
            "text": "Starts in the overhang near the corner of the crag. Follow the bolts.",
