  "translations": {
    "en": {
      "description": {
        "text": "Crag located in a green space within a residential area. Relatively dark and gloomy setting among the fir trees, providing some shade. Vertical, compact wall of the harder variety. There are quite a few rusty bolts and other fixed gear, and the wall generally offers relatively few natural placements.\n\nA smaller wall to the left of the main one features slightly overhanging rock, with easier routes and better sun exposure. Some caution is advised for nettles.\n\nA smaller wall further to the right of the main crag offers overhanging routes.",
        "method": "llm",
        "model": "gpt-4o-mini",
        "sourceIds": [
          "legacy:tumbaklippan"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tumbaklippan"
            ]
          },
          "body": {
            "text": "Crag in a green area within a residential neighbourhood. Relatively dark and gloomy spot among the pines, providing some shade. Vertical compact wall of the harder type. A fair number of rusty bolt hangers and other fixings are in the wall, which otherwise offers relatively few natural placements.\n\nA smaller wall, extending to the left of the main one, offers slightly overhanging rock with easier routes and also more sun exposure. Caution advised for nettles.\n\nA smaller wall further away, to the right of the main wall, offers overhanging routes.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tumbaklippan"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tumbaklippan"
            ]
          },
          "body": {
            "text": "Turn off Dalvägen in Tumba towards Storvreten. After 1 km, take a left onto Odlingsvägen towards Storvretsskolan. Park by the swimming area. If using public transport, take the bus towards Storvreten from Tumba station.",
            "method": "llm",
            "model": "gpt-4o-mini",
            "sourceIds": [
              "legacy:tumbaklippan"
            ]
          }
        },
        "leder": {
