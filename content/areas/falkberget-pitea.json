  "translations": {
    "en": {
      "description": {
        "text": "A 10m-high wall that is mainly top-roped. Slabby on the right and overhanging on the left. It can be useful to bring a length of static rope for rigging top-rope anchors.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:falkberget-pitea"
        ]
      },
      "sections": {
