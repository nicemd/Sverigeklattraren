            "text": "Right-hand side",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:falkberget-pitea"
            ]
          },
          "body": {
            "text": "Virtually every millimetre of this slabby face has probably been climbed, but only one route is usually led.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:falkberget-pitea"
