        },
        "access": {
          "title": {
            "text": "Access",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallinden"
            ]
          },
          "body": {
            "text": "Parking for Hallinden has changed since the old guidebook was published in 2002. Park at the Hallinden park-and-ride. The old parking area must not be used, and do not even consider driving along the tractor track to the crag. This has happened repeatedly and is ABSOLUTELY not permitted. If it happens again, we risk the crag being closed.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallinden"
            ]
          }
        },
