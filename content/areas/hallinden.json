  "translations": {
    "en": {
      "description": {
        "text": "NB: Parking is only permitted at Hallinden bus station. Do not drive along the farm track leading to Stora väggen!",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:hallinden"
        ]
      },
      "sections": {
        "introduktion": {
          "title": {
            "text": "Introduction",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallinden"
            ]
          },
          "body": {
            "text": "One of Sweden’s finest and most important crags. This is the first crag you see when approaching Lysekil from the E6, and an absolute must for visitors. The routes are long (up to 50 m), generally following excellent, well-protected cracks of varying widths, and the rock is almost overhanging in places. The routes start at 5+, but you should be climbing around 6+ or even 7- to get on the best lines. The climbing is often fairly grown-up and requires good jamming skills. Beyond that, it is hard going, with many routes in the grade 8 range. The base of the crag is flat and pleasant, with both shade and sun, making it suitable for families with children too. The sun reaches Stora väggen at around two o’clock, while tall trees shade Branta väggen for most of the day.\n\nFollow the parking instructions carefully; see Access below.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallinden"
            ]
          }
        },
        "vagbeskrivning": {
          "title": {
            "text": "Directions",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:hallinden"
            ]
