  "translations": {
    "en": {
      "description": {
        "text": "17 documented routes and problems.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:progressionsforare"
        ]
      },
      "sections": {
        "vad-ar-en-progressionsforare": {
          "title": {
            "text": "What is a progression guide?",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          },
          "body": {
            "text": "This is a bit of fun: a way of ordering Sweden’s finest, most beautiful, most characteristic or most unique lines. They are arranged in the order that climbers should tick them, if they happen to have a teleportation device at home and can get anywhere instantly. This means the order is not necessarily determined by grade – for example, a harder route may be well protected and worth attempting earlier than an easier but more serious outing.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "sveriges-finaste-linjer": {
          "title": {
            "text": "Sweden’s finest lines",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          },
          "body": {
            "text": "",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        }
      },
      "routes": {
        "progressionsforare-led-1": {
          "description": {
            "text": "Enjoyable, well-bolted route. Exposed for the grade, with excellent climbing.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-2": {
          "description": {
            "text": "Follow the Vita leden crack, then move left beneath a roof. Climb into the cave and belay. The second pitch exits through the other side of the cave and continues up the wall. Well protected with nuts.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-3": {
          "description": {
            "text": "Exposed, enjoyable and well protected. A brilliant route at the grade.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-4": {
          "description": {
            "text": "Rösås’s finest route, following a straight line up one of the crag’s highest and steepest sections. Frequently climbed. Usually climbed in three pitches. The final pitch is memorable. The second pitch can feel a little difficult to protect. Almost moss-free, with compact rock. Shares a start with the bolted route.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-6": {
          "description": {
            "text": "A beautiful line.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-7": {
          "description": {
            "text": "Consistently excellent climbing all the way to the top. Varied and more technical than strenuous. Balancy at the start. Well protected.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-8": {
          "description": {
            "text": "A classic on an imposing crag.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-9": {
          "description": {
            "text": "Varied and sustained. Jamming, underclings, traversing – everything. One of Sweden’s finest 6- routes.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-10": {
          "description": {
            "text": "A true classic and a test-piece for 6+ climbers.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-11": {
          "description": {
            "text": "The first pitch is one of Sweden’s finest crack lines.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-12": {
          "description": {
            "text": "A beautiful, sustained line. It would probably have been a trad classic had it not been in a sport climbing area.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-13": {
          "description": {
            "text": "A classic jug haul.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-14": {
          "description": {
            "text": "The first pitch follows a steep, unforgiving and pumpy crack; the second follows a holdless open corner. Fantastic.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-16": {
          "description": {
            "text": "Hand and fist jams in a roof crack that leads into a steep crack.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        },
        "progressionsforare-led-17": {
          "description": {
            "text": "Sport climbing doesn’t get any better than this – the finest route in Niemisel.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:progressionsforare"
            ]
          }
        }
      }
