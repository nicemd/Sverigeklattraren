  "translations": {
    "en": {
      "description": {
        "text": "Small, steep crag on the back of Henriksdalsberget, directly below the Henriksdal residential area. The rock is nowhere near as loose as it looks. The typical route offers steep climbing on large holds. A good evening crag for warm summer evenings.",
        "method": "llm",
        "model": "gpt-5.6-sol",
        "sourceIds": [
          "legacy:henriksdalsberget"
        ]
      },
      "sections": {
        "allmant": {
          "title": {
            "text": "General",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:henriksdalsberget"
            ]
          },
          "body": {
            "text": "A small, steep wall on the back of Henriksdalsberget, just below the Henriksdal residential area. The rock is nowhere near as loose as it looks. A typical route offers overhanging climbing on large holds. A good evening crag for warm summer evenings.",
            "method": "llm",
            "model": "gpt-5.6-sol",
            "sourceIds": [
              "legacy:henriksdalsberget"
            ]
          }
        },
        "miljo": {
          "title": {
            "text": "Aspect:",
            "method": "llm",
